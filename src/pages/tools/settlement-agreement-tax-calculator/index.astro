---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { TAX_YEAR, CURRENT_YEAR, TAX_FREE_COMPENSATION_LIMIT, PERSONAL_ALLOWANCE, BASIC_RATE_LIMIT, ADDITIONAL_RATE_THRESHOLD, BASIC_RATE, HIGHER_RATE, ADDITIONAL_RATE, NI_PRIMARY_THRESHOLD_WEEKLY, NI_UPPER_EARNINGS_LIMIT_WEEKLY, NI_RATE_MAIN, NI_RATE_UPPER } from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Settlement Agreement Tax Calculator' }
];

const relatedToolIds = ['tribunal-deadline', 'constructive-dismissal', 'tupe-rights'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Settlement Agreement Tax Calculator UK",
    "url": "https://fairworkcheck.co.uk/tools/settlement-agreement-tax-calculator/",
    "description": "Calculate the tax-free and taxable portions of your UK settlement agreement and estimate your net take-home pay after tax. Updated for HMRC rules and tax rates 2025/26.",
    "applicationCategory": "LegalApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
    "provider": { "@type": "Organization", "name": "FairWorkCheck", "url": "https://fairworkcheck.co.uk" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fairworkcheck.co.uk/" },
      { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://fairworkcheck.co.uk/tools/" },
      { "@type": "ListItem", "position": 3, "name": "Settlement Agreement Tax Calculator" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much of a settlement agreement is tax free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Under UK tax law, the first £30,000 of a genuine compensation payment for loss of employment in a settlement agreement is tax free. This applies to ex-gratia payments made as compensation for losing your job. However, payments for wages, notice pay (PILON), holiday pay, and bonus are all fully taxable and subject to income tax and National Insurance, regardless of how the agreement labels them. Only the genuine compensatory element can benefit from the £30,000 exemption."
        }
      },
      {
        "@type": "Question",
        "name": "Is notice pay in a settlement agreement taxable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Since April 2018, all payments in lieu of notice (PILON) are fully taxable and subject to both income tax and National Insurance contributions, regardless of whether your contract contains a PILON clause. This is known as Post-Employment Notice Pay (PENP). Even if your settlement agreement attempts to label notice pay as compensation, HMRC requires it to be taxed. Your employer must calculate the PENP amount and deduct tax and NI before paying you."
        }
      },
      {
        "@type": "Question",
        "name": "Do I pay National Insurance on a settlement agreement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on the component. Wages arrears, notice pay (PILON), holiday pay and bonus payments in a settlement agreement are subject to both income tax and National Insurance contributions. The genuine compensation for loss of employment element — up to £30,000 — is free from both income tax and National Insurance. Any compensation above £30,000 is subject to income tax only, not National Insurance."
        }
      },
      {
        "@type": "Question",
        "name": "What is the £30,000 tax free allowance for settlement agreements?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The £30,000 tax exemption applies to genuine ex-gratia payments made as compensation for loss of employment. It is a lifetime allowance that applies per employment, not per tax year. The exemption covers the compensatory element of a settlement — not contractual payments like wages, notice pay or holiday pay. Payments above £30,000 that are genuinely compensatory are taxed as income but are not subject to National Insurance contributions."
        }
      },
      {
        "@type": "Question",
        "name": "Should I get legal advice before signing a settlement agreement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — you are legally required to receive independent legal advice before signing a settlement agreement. A settlement agreement is only legally valid if you have received advice from a qualified independent adviser, such as a solicitor, certified trade union official, or advice centre worker. Your employer will usually contribute to the cost of this legal advice. Do not sign a settlement agreement without first receiving independent legal advice on its terms and your rights."
        }
      }
    ]
  }
];
---

<BaseLayout
  title={`Settlement Agreement Tax Calculator UK ${CURRENT_YEAR} — How Much Is Tax Free? | FairWorkCheck`}
  description={`Calculate the tax-free and taxable portions of your UK settlement agreement. Find your net take-home after income tax and NI. Free tool, updated for HMRC ${TAX_YEAR} rules.`}
  canonical="https://fairworkcheck.co.uk/tools/settlement-agreement-tax-calculator/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <!-- Ad Unit 1 -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="tool-top">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center">
      <div class="text-xs text-gray-400 mb-1">Advertisement</div>
      <div class="h-14 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-xs max-w-3xl mx-auto">
        <!-- 728x90 Leaderboard / 320x50 Mobile -->
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 px-3 py-1.5 rounded-full text-xs font-semibold mb-5 border border-emerald-100">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        HMRC rules · £30,000 exemption · {TAX_YEAR} tax rates
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
        Settlement Agreement Tax Calculator UK
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-6 max-w-2xl">
        Find out exactly how much of your settlement agreement is tax-free, how much tax you will pay, and your real net take-home figure — before you sign. Updated for HMRC rules and UK tax rates {TAX_YEAR}.
      </p>
      <div class="flex flex-wrap gap-3">
        {['Free to Use', 'No Registration', 'Instant Results', `HMRC Rules ${TAX_YEAR}`].map(badge => (
          <span class="inline-flex items-center gap-1.5 text-sm text-success bg-green-50 px-3 py-1 rounded-full border border-green-100 font-medium">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- IMPORTANT WARNING BANNER -->
  <div class="bg-amber-50 border-y border-amber-200">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-start gap-3">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c97b2a" stroke-width="2" class="flex-shrink-0 mt-0.5"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      <div>
        <p class="text-sm font-semibold text-amber-800 mb-1">Legal Requirement Before Signing</p>
        <p class="text-sm text-amber-700 leading-relaxed">
          You are legally required to receive independent legal advice before signing a settlement agreement. It is not legally valid without it. This calculator gives you an estimate only — always have your agreement reviewed by a qualified employment solicitor.
          <a href="/disclaimer/" class="underline ml-1">Read our full disclaimer →</a>
        </p>
      </div>
    </div>
  </div>

  <!-- Main Tool Section -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Tool Card -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-orange overflow-hidden">
            <div class="p-6 md:p-8">
              <h2 class="font-heading text-xl font-bold text-text-primary mb-2 flex items-center gap-2">
                <span class="text-2xl">💷</span> Calculate Your Settlement Agreement Tax
              </h2>
              <p class="text-sm text-text-secondary mb-8 leading-relaxed">
                Enter the breakdown of your settlement agreement below. Different payment types are taxed differently — enter each separately for an accurate result. All figures should be gross (before tax).
              </p>

              <!-- SECTION 1: Tax Band -->
              <div class="mb-8">
                <h3 class="font-semibold text-text-primary text-sm mb-4 flex items-center gap-2">
                  <span class="w-6 h-6 bg-navy rounded-full text-white text-xs flex items-center justify-center font-bold flex-shrink-0">1</span>
                  Your Income Tax Band
                </h3>
                <p class="text-xs text-text-secondary mb-3 ml-8">This should be your tax band during the tax year you receive the settlement, taking into account your normal salary plus any taxable settlement payments.</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                  {[
                    { value: 'basic', label: 'Basic Rate', rate: '20%', range: 'Income £12,571–£50,270' },
                    { value: 'higher', label: 'Higher Rate', rate: '40%', range: 'Income £50,271–£125,140' },
                    { value: 'additional', label: 'Additional Rate', rate: '45%', range: 'Income above £125,140' },
                  ].map(band => (
                    <label class="tax-band-option flex flex-col p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 transition-all text-center">
                      <input type="radio" name="tax-band" value={band.value} class="hidden" />
                      <span class="font-heading text-2xl font-bold text-navy mb-1">{band.rate}</span>
                      <span class="font-semibold text-sm text-text-primary mb-1">{band.label}</span>
                      <span class="text-xs text-text-secondary">{band.range}</span>
                    </label>
                  ))}
                </div>
                <p id="band-error" class="text-red-500 text-xs mt-2 hidden">Please select your tax band.</p>
              </div>

              <!-- SECTION 2: Payment Breakdown -->
              <div class="mb-8">
                <h3 class="font-semibold text-text-primary text-sm mb-1 flex items-center gap-2">
                  <span class="w-6 h-6 bg-navy rounded-full text-white text-xs flex items-center justify-center font-bold flex-shrink-0">2</span>
                  Your Settlement Agreement Breakdown
                </h3>
                <p class="text-xs text-text-secondary mb-5 ml-8">Enter each payment type separately. Leave blank or enter £0 if not applicable.</p>

                <div class="space-y-4">

                  <!-- Wages Arrears -->
                  <div class="payment-row rounded-xl border border-gray-100 overflow-hidden">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-gray-50 cursor-pointer payment-toggle text-left" data-target="wages-detail" aria-controls="wages-detail" aria-expanded="false" aria-label="Toggle wages and salary arrears payment details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-sm flex-shrink-0">💰</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Wages / Salary Arrears</p>
                          <p class="text-xs text-text-secondary">Any unpaid salary or wages owed to you</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full font-semibold">Fully Taxable + NI</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-gray-100" id="wages-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Gross amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="wages" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="taxable-ni" />
                          </div>
                        </div>
                        <div class="bg-red-50 rounded-lg p-3 text-xs text-red-700 leading-relaxed">
                          Wages arrears are fully subject to income tax AND National Insurance — the same as your normal salary.
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Notice Pay (PILON) -->
                  <div class="payment-row rounded-xl border border-gray-100 overflow-hidden">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-gray-50 cursor-pointer payment-toggle text-left" data-target="pilon-detail" aria-controls="pilon-detail" aria-expanded="false" aria-label="Toggle notice pay (PILON) payment details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-sm flex-shrink-0">📅</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Notice Pay (PILON)</p>
                          <p class="text-xs text-text-secondary">Payment in lieu of working your notice period</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full font-semibold">Fully Taxable + NI</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-gray-100" id="pilon-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Gross amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="pilon" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="taxable-ni" />
                          </div>
                        </div>
                        <div class="bg-red-50 rounded-lg p-3 text-xs text-red-700 leading-relaxed">
                          Since April 2018 all PILON is subject to income tax AND National Insurance — regardless of whether your contract had a PILON clause.
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Holiday Pay -->
                  <div class="payment-row rounded-xl border border-gray-100 overflow-hidden">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-gray-50 cursor-pointer payment-toggle text-left" data-target="holiday-detail" aria-controls="holiday-detail" aria-expanded="false" aria-label="Toggle accrued holiday pay payment details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-sm flex-shrink-0">🌴</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Accrued Holiday Pay</p>
                          <p class="text-xs text-text-secondary">Payment for untaken holiday entitlement</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full font-semibold">Fully Taxable + NI</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-gray-100" id="holiday-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Gross amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="holiday" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="taxable-ni" />
                          </div>
                        </div>
                        <div class="bg-red-50 rounded-lg p-3 text-xs text-red-700 leading-relaxed">
                          Accrued holiday pay is treated as earnings and is fully subject to income tax and National Insurance contributions.
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Bonus -->
                  <div class="payment-row rounded-xl border border-gray-100 overflow-hidden">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-gray-50 cursor-pointer payment-toggle text-left" data-target="bonus-detail" aria-controls="bonus-detail" aria-expanded="false" aria-label="Toggle bonus and commission payment details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-sm flex-shrink-0">⭐</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Bonus / Commission</p>
                          <p class="text-xs text-text-secondary">Any contractual or discretionary bonus payment</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full font-semibold">Fully Taxable + NI</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-gray-100" id="bonus-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Gross amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="bonus" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="taxable-ni" />
                          </div>
                        </div>
                        <div class="bg-red-50 rounded-lg p-3 text-xs text-red-700 leading-relaxed">
                          Bonus and commission payments due under your contract are fully taxable and subject to National Insurance.
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Compensation for Loss of Employment -->
                  <div class="payment-row rounded-xl border border-navy/20 overflow-hidden ring-1 ring-navy/10">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-green-50 cursor-pointer payment-toggle text-left" data-target="compensation-detail" aria-controls="compensation-detail" aria-expanded="false" aria-label="Toggle compensation for loss of employment details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-sm flex-shrink-0">✅</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Compensation for Loss of Employment</p>
                          <p class="text-xs text-text-secondary">Ex-gratia payment — the tax-advantaged element</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full font-semibold">First £30k Tax Free</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-green-100" id="compensation-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Gross amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="compensation" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="compensation" />
                          </div>
                        </div>
                        <div class="bg-green-50 rounded-lg p-3 text-xs text-green-700 leading-relaxed">
                          The first £30,000 of genuine compensation for loss of employment is free from income tax AND National Insurance. Any amount above £30,000 is subject to income tax only (not NI).
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Legal Costs -->
                  <div class="payment-row rounded-xl border border-gray-100 overflow-hidden">
                    <button type="button" class="w-full flex items-center justify-between p-4 bg-gray-50 cursor-pointer payment-toggle text-left" data-target="legal-detail" aria-controls="legal-detail" aria-expanded="false" aria-label="Toggle legal fee contribution details">
                      <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-sm flex-shrink-0">⚖️</span>
                        <div>
                          <p class="font-semibold text-sm text-text-primary">Employer Contribution to Legal Fees</p>
                          <p class="text-xs text-text-secondary">Payment towards your solicitor's fees for reviewing the agreement</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="tax-tag bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full font-semibold">Tax Free</span>
                        <svg class="w-4 h-4 text-gray-400 toggle-arrow transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                      </div>
                    </button>
                    <div class="payment-detail hidden p-4 border-t border-gray-100" id="legal-detail">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                          <label class="block text-xs font-semibold text-text-secondary mb-1.5">Amount (£)</label>
                          <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">£</span>
                            <input type="number" id="legal" class="payment-input w-full border border-gray-200 rounded-lg pl-7 pr-3 py-2.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-navy/30 focus:border-navy bg-white transition-all" placeholder="0.00" min="0" step="0.01" data-type="tax-free" />
                          </div>
                        </div>
                        <div class="bg-blue-50 rounded-lg p-3 text-xs text-blue-700 leading-relaxed">
                          Payments made directly to your solicitor for advising you on the agreement are tax free. This does not count towards the £30,000 limit.
                        </div>
                      </div>
                    </div>
                  </div>

                </div>

                <!-- Live Running Total -->
                <div class="mt-5 bg-navy rounded-xl p-4">

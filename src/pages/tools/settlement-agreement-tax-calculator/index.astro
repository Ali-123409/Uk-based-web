---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { 
  TAX_YEAR, 
  CURRENT_YEAR, 
  TAX_FREE_COMPENSATION_LIMIT, 
  BASIC_RATE, 
  HIGHER_RATE, 
  ADDITIONAL_RATE, 
  NI_RATE_MAIN 
} from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Settlement Agreement Tax Calculator' }
];

const relatedToolIds = ['tribunal-deadline', 'constructive-dismissal', 'tupe-rights'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Settlement Agreement Tax Calculator UK",
    "url": "https://fairworkcheck.co.uk/tools/settlement-agreement-tax-calculator/",
    "description": "Calculate the tax-free and taxable portions of your UK settlement agreement and estimate your net take-home pay after tax.",
    "applicationCategory": "LegalApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
    "provider": { "@type": "Organization", "name": "FairWorkCheck", "url": "https://fairworkcheck.co.uk" }
  }
];
---

<BaseLayout
  title={`Settlement Agreement Tax Calculator UK ${CURRENT_YEAR} — How Much Is Tax Free? | FairWorkCheck`}
  description={`Calculate the tax-free and taxable portions of your UK settlement agreement. Updated for HMRC ${TAX_YEAR} rules.`}
  canonical="https://fairworkcheck.co.uk/tools/settlement-agreement-tax-calculator/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <!-- Ad Unit -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="tool-top">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center">
      <div class="text-xs text-gray-400 mb-1">Advertisement</div>
      <div class="h-14 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-xs max-w-3xl mx-auto"></div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 px-3 py-1.5 rounded-full text-xs font-semibold mb-5 border border-emerald-100">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        HMRC rules · £30,000 exemption · {TAX_YEAR} tax rates
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
        Settlement Agreement Tax Calculator UK
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-6 max-w-2xl">
        Find out exactly how much of your settlement agreement is tax-free, how much tax you will pay, and your real net take-home figure.
      </p>
    </div>
  </section>

  <!-- Legal Warning Banner -->
  <div class="bg-amber-50 border-y border-amber-200">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-start gap-3">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c97b2a" stroke-width="2" class="flex-shrink-0 mt-0.5"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      <div>
        <p class="text-sm font-semibold text-amber-800 mb-1">Legal Requirement Before Signing</p>
        <p class="text-sm text-amber-700 leading-relaxed">
          You are legally required to receive independent legal advice before signing a settlement agreement. This calculator provides an estimate only.
        </p>
      </div>
    </div>
  </div>

  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Input Section -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-orange overflow-hidden">
            <div class="p-6 md:p-8">
              <h2 class="font-heading text-xl font-bold text-text-primary mb-6">1. Your Income Tax Band</h2>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
                {[
                  { value: 'basic', label: 'Basic Rate', rate: '20%' },
                  { value: 'higher', label: 'Higher Rate', rate: '40%' },
                  { value: 'additional', label: 'Additional Rate', rate: '45%' },
                ].map(band => (
                  <label class="tax-band-option flex flex-col p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy text-center">
                    <input type="radio" name="tax-band" value={band.value} class="hidden" />
                    <span class="text-2xl font-bold text-navy">{band.rate}</span>
                    <span class="text-sm font-semibold">{band.label}</span>
                  </label>
                ))}
              </div>

              <h2 class="font-heading text-xl font-bold text-text-primary mb-6">2. Payment Breakdown</h2>
              <div class="space-y-4 mb-8">
                <!-- Compensation Row -->
                <div class="rounded-xl border border-gray-100 overflow-hidden">
                   <div class="p-4 bg-gray-50 flex justify-between items-center">
                      <span class="font-semibold">Ex-gratia Compensation</span>
                      <input type="number" id="compensation" class="payment-input border p-2 rounded w-32" placeholder="0.00" />
                   </div>
                </div>
                <!-- PILON Row -->
                <div class="rounded-xl border border-gray-100 overflow-hidden">
                   <div class="p-4 bg-gray-50 flex justify-between items-center">
                      <span class="font-semibold">Notice Pay (PILON)</span>
                      <input type="number" id="pilon" class="payment-input border p-2 rounded w-32" placeholder="0.00" />
                   </div>
                </div>
                <!-- Holiday Row -->
                <div class="rounded-xl border border-gray-100 overflow-hidden">
                   <div class="p-4 bg-gray-50 flex justify-between items-center">
                      <span class="font-semibold">Holiday Pay</span>
                      <input type="number" id="holiday" class="payment-input border p-2 rounded w-32" placeholder="0.00" />
                   </div>
                </div>
              </div>

              <button id="calculate-btn" class="w-full bg-orange text-white py-4 rounded-xl font-bold text-lg">Calculate Net Take-Home</button>
            </div>
          </div>

          <!-- Results Section -->
          <div id="results-section" class="hidden mt-8">
            <div class="bg-navy rounded-2xl p-8 text-white text-center">
                <p class="text-gray-300">Estimated Net Take-Home</p>
                <div id="r-net-takehome" class="text-5xl font-bold my-2"></div>
                <div id="r-net-subtitle" class="text-sm text-gray-400"></div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-5">
          <div class="bg-navy rounded-xl p-5 text-white">
            <h3 class="font-bold mb-4">Tax Treatment</h3>
            <div class="space-y-3">
              {[
                { label: 'Wages arrears', tag: 'Tax + NI', color: 'bg-red-400' },
                { label: 'Notice pay (PILON)', tag: 'Tax + NI', color: 'bg-red-400' },
                { label: 'Compensation (first £30k)', tag: 'Tax Free', color: 'bg-green-400' },
                { label: 'Compensation (over £30k)', tag: 'Tax only', color: 'bg-amber-400' },
                { label: 'Legal fee contribution', tag: 'Tax Free', color: 'bg-green-400' },
              ].map(r => (
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-300 text-xs">{r.label}</span>
                  <span class={`text-xs px-2 py-0.5 rounded-full text-white font-semibold ${r.color}`}>{r.tag}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-white border rounded-xl p-4">
            <h3 class="font-bold text-sm mb-3">Tax Rates {TAX_YEAR}</h3>
            <div class="space-y-2.5 text-xs">
              {[
                { label: 'Personal allowance', value: '£12,570' },
                { label: 'Basic rate (20%)', value: '£12,571–£50,270' },
                { label: 'Tax-free compensation', value: '£30,000' },
              ].map(r => (
                <div class="flex justify-between border-b pb-2">
                  <span class="text-gray-500">{r.label}</span>
                  <span class="font-bold">{r.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script define:vars={{ TAX_FREE_COMPENSATION_LIMIT, BASIC_RATE, HIGHER_RATE, ADDITIONAL_RATE, NI_RATE_MAIN }}>
  document.addEventListener('DOMContentLoaded', () => {
    const TAX_RATES = {
        basic: BASIC_RATE,
        higher: HIGHER_RATE,
        additional: ADDITIONAL_RATE
    };

    function fmt(n) {
        return '£' + n.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    document.getElementById('calculate-btn')?.addEventListener('click', () => {
        const band = document.querySelector('input[name="tax-band"]:checked')?.value || 'basic';
        const comp = parseFloat(document.getElementById('compensation').value) || 0;
        const pilon = parseFloat(document.getElementById('pilon').value) || 0;
        const holiday = parseFloat(document.getElementById('holiday').value) || 0;

        const taxRate = TAX_RATES[band];
        
        // Taxable elements (Notice and Holiday pay always attract Tax + NI)
        const taxableWithNI = pilon + holiday;
        const taxOnEarned = taxableWithNI * taxRate;
        const niOnEarned = taxableWithNI * NI_RATE_MAIN;

        // Compensation element (£30k rule)
        const compTaxFree = Math.min(comp, TAX_FREE_COMPENSATION_LIMIT);
        const compTaxable = Math.max(0, comp - TAX_FREE_COMPENSATION_LIMIT);
        const taxOnComp = compTaxable * taxRate; // No NI on redundancy excess

        const totalNet = (comp + pilon + holiday) - (taxOnEarned + niOnEarned + taxOnComp);

        const netEl = document.getElementById('r-net-takehome');
        if (netEl) netEl.textContent = fmt(totalNet);
        
        document.getElementById('results-section')?.classList.remove('hidden');
    });
  });
</script>

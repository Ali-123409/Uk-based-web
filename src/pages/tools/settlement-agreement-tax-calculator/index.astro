<script define:vars={{ TAX_FREE_COMPENSATION_LIMIT, PERSONAL_ALLOWANCE, BASIC_RATE_LIMIT, ADDITIONAL_RATE_THRESHOLD, BASIC_RATE, HIGHER_RATE, ADDITIONAL_RATE, NI_PRIMARY_THRESHOLD_WEEKLY, NI_UPPER_EARNINGS_LIMIT_WEEKLY, NI_RATE_MAIN, NI_RATE_UPPER }}>
  document.addEventListener('DOMContentLoaded', () => {
  // Tax rates 2025/26
  // TAX_FREE_COMPENSATION_LIMIT injected via define:vars from src/data/config.ts
  // NI_RATE_MAIN (0.08) injected from config.ts — was NI_RATE_MAIN

  // Tax rates injected from config.ts via define:vars
  const TAX_RATES: Record<string, number> = {
    basic: BASIC_RATE,
    higher: HIGHER_RATE,
    additional: ADDITIONAL_RATE,
  };

  // NI_UPPER_EARNINGS_LIMIT_WEEKLY injected via define:vars from config.ts

  // Formatting
  function fmt(n: number): string {
    return `£${n.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  }

  // Tax band visual selection
  document.querySelectorAll('.tax-band-option').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('.tax-band-option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      const radio = opt.querySelector('input[type="radio"]') as HTMLInputElement;
      if (radio) radio.checked = true;
      updateLiveTotals();
    });
  });

  // Toggle payment rows
  document.querySelectorAll('.payment-toggle').forEach((el: Element) => {
    const toggle = el as HTMLButtonElement;
    toggle.addEventListener('click', () => {
      const targetId = (toggle as HTMLElement).dataset.target;
      if (!targetId) return;
      const detail = document.getElementById(targetId);
      const arrow = toggle.querySelector('.toggle-arrow');
      if (detail) {
        const isNowOpen = detail.classList.toggle('hidden') === false;
        arrow?.classList.toggle('rotate-180');
        toggle.setAttribute('aria-expanded', String(isNowOpen));
      }
    });
  });

  // Live totals
  function getValues() {
    const wages = parseFloat((document.getElementById('wages') as HTMLInputElement)?.value) || 0;
    const pilon = parseFloat((document.getElementById('pilon') as HTMLInputElement)?.value) || 0;
    const holiday = parseFloat((document.getElementById('holiday') as HTMLInputElement)?.value) || 0;
    const bonus = parseFloat((document.getElementById('bonus') as HTMLInputElement)?.value) || 0;
    const compensation = parseFloat((document.getElementById('compensation') as HTMLInputElement)?.value) || 0;
    const legal = parseFloat((document.getElementById('legal') as HTMLInputElement)?.value) || 0;
    return { wages, pilon, holiday, bonus, compensation, legal };
  }

  function getSelectedBand(): string | null {
    const checked = document.querySelector('input[name="tax-band"]:checked') as HTMLInputElement;
    return checked ? checked.value : null;
  }

  function calculateTax(values: ReturnType<typeof getValues>, band: string | null) {
    const taxRate = band ? TAX_RATES[band] : 0.20;
    const niRate = NI_RATE_MAIN;

    const taxableNI = values.wages + values.pilon + values.holiday + values.bonus;
    const taxOnTaxableNI = taxableNI * taxRate;
    const niOnTaxableNI = taxableNI * niRate;

    const compTaxFree = Math.min(values.compensation, TAX_FREE_COMPENSATION_LIMIT);
    const compTaxable = Math.max(0, values.compensation - TAX_FREE_COMPENSATION_LIMIT);
    const taxOnCompExcess = compTaxable * taxRate;
    // No NI on compensation above £30k

    const totalTax = taxOnTaxableNI + taxOnCompExcess;
    const totalNI = niOnTaxableNI;
    const totalTaxFree = compTaxFree + values.legal;
    const grossTotal = values.wages + values.pilon + values.holiday + values.bonus + values.compensation + values.legal;
    const netTotal = grossTotal - totalTax - totalNI;

    return {
      taxRate, taxableNI, taxOnTaxableNI, niOnTaxableNI,
      compTaxFree, compTaxable, taxOnCompExcess,
      totalTax, totalNI, totalTaxFree, grossTotal, netTotal,
      values
    };
  }

  function updateLiveTotals() {
    const vals = getValues();
    const band = getSelectedBand();
    const calc = calculateTax(vals, band);

    const liveTotal = document.getElementById('live-total');
    const liveTaxfree = document.getElementById('live-taxfree');
    const liveTax = document.getElementById('live-tax');

    if (liveTotal) liveTotal.textContent = fmt(calc.grossTotal);
    if (liveTaxfree) liveTaxfree.textContent = fmt(calc.totalTaxFree);
    if (liveTax) liveTax.textContent = fmt(calc.totalTax + calc.totalNI);
  }

  document.querySelectorAll('.payment-input').forEach(input => {
    input.addEventListener('input', updateLiveTotals);
  });

  // Main calculate
  document.getElementById('calculate-btn')?.addEventListener('click', () => {
    const band = getSelectedBand();
    const vals = getValues();
    const calcError = document.getElementById('calc-error');
    const bandError = document.getElementById('band-error');

    const total = vals.wages + vals.pilon + vals.holiday + vals.bonus + vals.compensation + vals.legal;

    if (!band) {
      bandError?.classList.remove('hidden');
      calcError?.classList.add('hidden');
      return;
    }
    bandError?.classList.add('hidden');

    if (total === 0) {
      calcError?.classList.remove('hidden');
      return;
    }
    calcError?.classList.add('hidden');

    const calc = calculateTax(vals, band);
    const bandLabels: Record<string, string> = { basic: 'Basic Rate (20%)', higher: 'Higher Rate (40%)', additional: 'Additional Rate (45%)' };

    // Net take-home hero
    const netHero = document.getElementById('r-net-takehome');
    const netSubtitle = document.getElementById('r-net-subtitle');
    if (netHero) netHero.textContent = fmt(calc.netTotal);
    if (netSubtitle) netSubtitle.textContent = `From a gross settlement of ${fmt(calc.grossTotal)} · ${bandLabels[band]} applied`;

    // Breakdown table
    const breakdownTable = document.getElementById('breakdown-table');
    const rows: Array<{ label: string; gross: number; taxFree: number; tax: number; ni: number; net: number; tag: string; tagColor: string }> = [];

    if (vals.wages > 0) {
      const tax = vals.wages * calc.taxRate;
      const ni = vals.wages * NI_RATE_MAIN;
      rows.push({ label: 'Wages / Salary Arrears', gross: vals.wages, taxFree: 0, tax, ni, net: vals.wages - tax - ni, tag: 'Taxable + NI', tagColor: 'text-red-600 bg-red-50' });
    }
    if (vals.pilon > 0) {
      const tax = vals.pilon * calc.taxRate;
      const ni = vals.pilon * NI_RATE_MAIN;
      rows.push({ label: 'Notice Pay (PILON)', gross: vals.pilon, taxFree: 0, tax, ni, net: vals.pilon - tax - ni, tag: 'Taxable + NI', tagColor: 'text-red-600 bg-red-50' });
    }
    if (vals.holiday > 0) {
      const tax = vals.holiday * calc.taxRate;
      const ni = vals.holiday * NI_RATE_MAIN;
      rows.push({ label: 'Accrued Holiday Pay', gross: vals.holiday, taxFree: 0, tax, ni, net: vals.holiday - tax - ni, tag: 'Taxable + NI', tagColor: 'text-red-600 bg-red-50' });
    }
    if (vals.bonus > 0) {
      const tax = vals.bonus * calc.taxRate;
      const ni = vals.bonus * NI_RATE_MAIN;
      rows.push({ label: 'Bonus / Commission', gross: vals.bonus, taxFree: 0, tax, ni, net: vals.bonus - tax - ni, tag: 'Taxable + NI', tagColor: 'text-red-600 bg-red-50' });
    }
    if (vals.compensation > 0) {
      rows.push({
        label: `Compensation for Loss of Employment`,
        gross: vals.compensation,
        taxFree: calc.compTaxFree,
        tax: calc.taxOnCompExcess,
        ni: 0,
        net: vals.compensation - calc.taxOnCompExcess,
        tag: vals.compensation <= TAX_FREE_COMPENSATION_LIMIT ? 'Tax Free' : `£${TAX_FREE_COMPENSATION_LIMIT.toLocaleString()} tax free`,
        tagColor: 'text-green-700 bg-green-50'
      });
    }
    if (vals.legal > 0) {
      rows.push({ label: 'Legal Fee Contribution', gross: vals.legal, taxFree: vals.legal, tax: 0, ni: 0, net: vals.legal, tag: 'Tax Free', tagColor: 'text-green-700 bg-green-50' });
    }

    if (breakdownTable) {
      breakdownTable.innerHTML = rows.map(row => `
        <div class="px-5 py-4">
          <div class="flex items-center justify-between mb-2">
            <span class="font-semibold text-sm text-text-primary">${row.label}</span>
            <span class="text-xs px-2 py-0.5 rounded-full font-semibold ${row.tagColor}">${row.tag}</span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs">
            <div><span class="text-text-secondary block">Gross</span><span class="font-semibold text-text-primary">${fmt(row.gross)}</span></div>
            <div><span class="text-text-secondary block">Income Tax</span><span class="font-semibold ${row.tax > 0 ? 'text-red-500' : 'text-green-600'}">${row.tax > 0 ? '-' + fmt(row.tax) : '—'}</span></div>
            <div><span class="text-text-secondary block">Nat. Insurance</span><span class="font-semibold ${row.ni > 0 ? 'text-red-500' : 'text-green-600'}">${row.ni > 0 ? '-' + fmt(row.ni) : '—'}</span></div>
            <div><span class="text-text-secondary block">Net</span><span class="font-semibold text-navy">${fmt(row.net)}</span></div>
          </div>
        </div>
      `).join('');
    }

    // Totals
    const setEl = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };
    setEl('r-gross-total', fmt(calc.grossTotal));
    setEl('r-total-taxfree', fmt(calc.totalTaxFree));
    setEl('r-total-tax', '-' + fmt(calc.totalTax));
    setEl('r-total-ni', '-' + fmt(calc.totalNI));
    setEl('r-net-total', fmt(calc.netTotal));

    // Tax band notice
    const taxBandNotice = document.getElementById('tax-band-notice');
    if (taxBandNotice) {
      taxBandNotice.innerHTML = `<strong>Tax band applied: ${bandLabels[band]}</strong> — Income tax deducted at ${(calc.taxRate * 100).toFixed(0)}% on taxable elements. Employee National Insurance deducted at 8% on earnings-type payments. Compensation above £30,000 is taxed at income tax rate only — no NI applies above the threshold.`;
    }

    // £30k warning
    const thirtyKWarning = document.getElementById('thirty-k-warning');
    const thirtyKText = document.getElementById('thirty-k-text');
    if (vals.compensation > TAX_FREE_COMPENSATION_LIMIT) {
      thirtyKWarning?.classList.remove('hidden');
      if (thirtyKText) {
        const excess = vals.compensation - TAX_FREE_COMPENSATION_LIMIT;
        thirtyKText.textContent = `Your compensation of ${fmt(vals.compensation)} exceeds the £30,000 tax-free limit. The first £30,000 is fully tax and NI free. The remaining ${fmt(excess)} is subject to income tax at ${(calc.taxRate * 100).toFixed(0)}% — but not National Insurance contributions. Tax on the excess: ${fmt(calc.taxOnCompExcess)}.`;
      }
    } else {
      thirtyKWarning?.classList.add('hidden');
    }

    // Next steps
    const nextStepsEl = document.getElementById('next-steps');
    const steps = [
      '⚖️ You are legally required to get independent legal advice before signing — your employer should pay for this',
      '📋 Ask your solicitor to review the payment breakdown to confirm the tax treatment is correct',
      `💷 Your net take-home estimate is ${fmt(calc.netTotal)} — confirm this figure with your solicitor before signing`,
      vals.compensation > TAX_FREE_COMPENSATION_LIMIT ? `⚠️ Your compensation exceeds £30,000 — confirm the tax treatment with HMRC or a tax adviser` : '✅ Your compensation is within the £30,000 tax-free limit',
      '📄 Do not sign until you have received and reviewed the solicitor\'s advice in writing',
      '💡 Consider whether the total offer is fair — your solicitor can advise on negotiation',
    ];

    if (nextStepsEl) {
      nextStepsEl.innerHTML = steps.map((step, i) =>
        `<li class="flex items-start gap-3 text-sm text-gray-200">
          <span class="w-5 h-5 bg-orange rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5">${i + 1}</span>
          <span>${step}</span>
        </li>`
      ).join('');
    }

    // Show results
    document.getElementById('results-section')?.classList.remove('hidden');
    document.getElementById('results-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Reset
  document.getElementById('reset-btn')?.addEventListener('click', () => {
    document.querySelectorAll('.payment-input').forEach(i => (i as HTMLInputElement).value = '');
    document.querySelectorAll('.tax-band-option').forEach(o => o.classList.remove('selected'));
    document.querySelectorAll('input[name="tax-band"]').forEach(r => (r as HTMLInputElement).checked = false);
    document.querySelectorAll('.payment-detail').forEach(d => d.classList.add('hidden'));
    document.querySelectorAll('.toggle-arrow').forEach(a => a.classList.remove('rotate-180'));
    document.getElementById('results-section')?.classList.add('hidden');
    document.getElementById('band-error')?.classList.add('hidden');
    document.getElementById('calc-error')?.classList.add('hidden');
    updateLiveTotals();
  });

  document.getElementById('restart-btn')?.addEventListener('click', () => {
    document.getElementById('reset-btn')?.click();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  });
</script>

<style>
  .answer-option:has(input:checked) { border-color: #7c3aed; background-color: rgba(124,58,237,0.05); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
  const TOTAL = 9;
  let current = 1;
  const answers: Record<string, string> = {};

  function show(n: number) {
    document.querySelectorAll('.question-slide').forEach(el => el.classList.add('hidden'));
    document.getElementById(`q${n}`)?.classList.remove('hidden');
    (document.getElementById('current-q') as HTMLElement).textContent = String(n);
    const pct = Math.round(((n - 1) / TOTAL) * 100);
    (document.getElementById('progress-pct') as HTMLElement).textContent = String(pct);
    (document.getElementById('progress-bar') as HTMLElement).style.width = `${pct}%`;
    const prev = document.getElementById('prev-btn')!;
    const next = document.getElementById('next-btn')!;
    const sub = document.getElementById('submit-btn')!;
    prev.classList.toggle('hidden', n === 1);
    next.classList.toggle('hidden', n === TOTAL);
    sub.classList.toggle('hidden', n !== TOTAL);
  }

  document.getElementById('next-btn')?.addEventListener('click', () => {
    const sel = document.querySelector(`input[name="q${current}"]:checked`) as HTMLInputElement;
    const errMsg = document.querySelector(`#q${current} .error-msg`) as HTMLElement;
    if (!sel) { errMsg?.classList.remove('hidden'); return; }
    errMsg?.classList.add('hidden');
    answers[`q${current}`] = sel.value;
    current++;
    show(current);
  });

  document.getElementById('prev-btn')?.addEventListener('click', () => {
    if (current > 1) { current--; show(current); }
  });

  document.getElementById('submit-btn')?.addEventListener('click', () => {
    const sel = document.querySelector(`input[name="q${TOTAL}"]:checked`) as HTMLInputElement;
    const errMsg = document.querySelector(`#q${TOTAL} .error-msg`) as HTMLElement;
    if (!sel) { errMsg?.classList.remove('hidden'); return; }
    errMsg?.classList.add('hidden');
    answers[`q${TOTAL}`] = sel.value;
    showResults();
  });

  document.getElementById('restart-btn')?.addEventListener('click', () => {
    document.querySelectorAll('input[type="radio"]').forEach((r: any) => r.checked = false);
    Object.keys(answers).forEach(k => delete answers[k]);
    current = 1;
    show(1);
    document.getElementById('results-panel')?.classList.add('hidden');
    document.getElementById('progress-section')?.classList.remove('hidden');
    document.getElementById('nav-buttons')?.classList.remove('hidden');
    document.querySelectorAll('.question-slide').forEach(el => el.classList.add('hidden'));
    document.getElementById('q1')?.classList.remove('hidden');
  });

  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      body.classList.toggle('hidden');
      icon.style.transform = body.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  });

  function showResults() {
    document.getElementById('progress-section')?.classList.add('hidden');
    document.getElementById('nav-buttons')?.classList.add('hidden');
    document.querySelectorAll('.question-slide').forEach(el => el.classList.add('hidden'));
    document.getElementById('results-panel')?.classList.remove('hidden');

    // Scoring
    const q1 = answers.q1;
    const q2 = answers.q2;
    const q3 = answers.q3;
    const q4 = answers.q4;
    const q5 = answers.q5;
    const q6 = answers.q6;
    const q7 = answers.q7;
    const q8 = answers.q8;
    const q9 = answers.q9;

    // Disclosure qualifies?
    const qualifyingSubject = ['criminal','legal_breach','health_safety','environment','miscarriage','cover_up'].includes(q1);
    const honestBelief = ['yes_certain','yes_reasonable','unsure'].includes(q2);
    const publicInterest = ['yes_clear','yes_mixed'].includes(q3);
    const properRecipient = ['employer','regulator','legal_adviser'].includes(q4);
    const workerStatus = ['employee','worker','contractor','trainee'].includes(q5);
    const retaliated = ['dismissed','detriment','constructive'].includes(q6);
    const quickRetaliation = q7 === 'immediate';
    const knownSource = ['yes_certain','suspected'].includes(q8);
    const hasEvidence = ['strong','partial'].includes(q9);

    const disclosureProtected = qualifyingSubject && honestBelief && publicInterest && properRecipient && workerStatus;
    const retaliationActionable = disclosureProtected && retaliated && (quickRetaliation || knownSource);

    let score = 0;
    if (qualifyingSubject) score += 3;
    if (honestBelief) score += 2;
    if (publicInterest) score += 2;
    if (properRecipient) score += 2;
    if (workerStatus) score += 1;
    if (retaliated) score += 2;
    if (quickRetaliation) score += 1;
    if (knownSource) score += 1;
    if (hasEvidence) score += 1;

    const MAX = 15;

    let heading = '', summary = '', icon = '', label = '';
    if (score >= 12 && disclosureProtected && retaliationActionable) {
      heading = 'Strong Protected Disclosure — Retaliation Likely Actionable';
      summary = 'Your disclosure appears to meet the criteria for a protected disclosure under PIDA, and the retaliation you experienced has strong indicators of being actionable at tribunal.';
      icon = '🛡️'; label = 'Well Protected';
    } else if (score >= 8 && disclosureProtected) {
      heading = 'Disclosure Likely Protected';
      summary = 'Your disclosure shows good indicators of being a protected disclosure. Whether any retaliation is actionable depends on the evidence and causal link — legal advice is strongly recommended.';
      icon = '✅'; label = 'Likely Protected';
    } else if (score >= 5) {
      heading = 'Partial Protection — Key Gaps Present';
      summary = 'Some elements of your situation suggest protection may apply, but there are significant gaps in the criteria. Professional legal advice is essential before taking any action.';
      icon = '⚠️'; label = 'Partial';
    } else {
      heading = 'Protection Unlikely on These Facts';
      summary = 'Based on your answers, your disclosure may not meet the criteria for a protected disclosure under PIDA. However, you may still have other employment law claims. Seek legal advice.';
      icon = '🔴'; label = 'Uncertain';
    }

    (document.getElementById('result-heading') as HTMLElement).textContent = heading;
    (document.getElementById('result-summary') as HTMLElement).textContent = summary;
    (document.getElementById('result-icon') as HTMLElement).textContent = icon;
    (document.getElementById('result-label') as HTMLElement).textContent = label;

    const breakdown = [
      { label: 'Qualifying subject matter', ok: qualifyingSubject, note: qualifyingSubject ? 'Your disclosure covers a qualifying category of wrongdoing.' : 'Personal grievances do not qualify as protected disclosures without a qualifying public interest element.' },
      { label: 'Honest belief in wrongdoing', ok: honestBelief, note: honestBelief ? 'You had a genuine, reasonable belief wrongdoing was occurring.' : 'Disclosures made without honest belief are not protected.' },
      { label: 'Public interest element', ok: publicInterest, note: publicInterest ? 'Your disclosure has a public interest component.' : 'Since 2013 disclosures must be in the public interest, not purely personal.' },
      { label: 'Proper disclosure recipient', ok: properRecipient, note: properRecipient ? 'You reported to an appropriate person or body.' : 'Disclosures only to colleagues or friends without any formal report may not be protected.' },
      { label: 'Worker status covered', ok: workerStatus, note: workerStatus ? 'Your working relationship is covered by PIDA.' : 'Fully self-employed individuals operating through a company may fall outside PIDA.' },
      { label: 'Retaliation / detriment occurred', ok: retaliated, note: retaliated ? 'You have experienced detriment — this is a separate actionable claim if linked to your disclosure.' : 'No retaliation experienced. You can still seek confirmation your disclosure was protected.' },
      { label: 'Evidence available', ok: hasEvidence, note: hasEvidence ? 'Evidence significantly strengthens your position before a tribunal.' : 'Lack of documentary evidence weakens a claim. Start preserving any records you have now.' },
    ];

    const breakdownEl = document.getElementById('result-breakdown')!;
    breakdownEl.innerHTML = breakdown.map(item => `
      <div class="flex items-start gap-3 p-3 rounded-lg ${item.ok ? 'bg-green-50 border border-green-100' : 'bg-red-50 border border-red-100'}">
        <span class="text-lg flex-shrink-0">${item.ok ? '✅' : '❌'}</span>
        <div>
          <p class="font-semibold text-sm text-text-primary">${item.label}</p>
          <p class="text-xs text-text-secondary mt-0.5">${item.note}</p>
        </div>
      </div>
    `).join('');

    const steps: string[] = [];
    if (!disclosureProtected) steps.push('Speak to an employment solicitor or contact <strong>Protect</strong> (whistleblowing charity) on 020 3117 2520 to discuss your specific situation.');
    if (retaliated) steps.push('Contact <strong>ACAS</strong> on 0300 123 1100 immediately — you must start Early Conciliation before filing a tribunal claim. Time limits are strict (3 months minus 1 day).');
    if (disclosureProtected && retaliated) steps.push('Start preserving all evidence now — emails, messages, records of incidents, and any witnesses who can support your account.');
    if (disclosureProtected && !retaliated) steps.push('Your disclosure appears protected. Keep a record of everything in case your employer takes action against you in future.');
    steps.push('Visit <strong>GOV.UK</strong> or <strong>ACAS</strong> for free guidance on whistleblowing rights at work.');

    (document.getElementById('result-steps') as HTMLElement).innerHTML = steps.map(s => `<p class="flex items-start gap-2"><span class="text-purple-600 flex-shrink-0">→</span><span>${s}</span></p>`).join('');
  }

  show(1);
  });
</script>

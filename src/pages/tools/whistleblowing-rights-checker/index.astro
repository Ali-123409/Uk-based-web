      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { num: '01', title: 'Answer 9 Questions', desc: 'Tell us what you reported, who you told, and what happened after.' },
          { num: '02', title: 'We Apply PIDA', desc: 'Your answers are assessed against the Public Interest Disclosure Act 1998 criteria.' },

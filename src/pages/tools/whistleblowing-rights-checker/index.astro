---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Whistleblowing Rights Checker' }
];

const relatedToolIds = ['constructive-dismissal', 'tribunal-deadline', 'acas-conciliation'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Whistleblowing Rights Checker UK",
    "url": "https://fairworkcheck.pakistanbill.online/tools/whistleblowing-rights-checker/",
    "description": "Check whether your disclosure qualifies as a protected disclosure under UK whistleblowing law and whether any retaliation you experienced is actionable.",
    "applicationCategory": "LegalApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
    "provider": { "@type": "Organization", "name": "FairWorkCheck", "url": "https://fairworkcheck.pakistanbill.online" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fairworkcheck.pakistanbill.online/" },
      { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://fairworkcheck.pakistanbill.online/tools/" },
      { "@type": "ListItem", "position": 3, "name": "Whistleblowing Rights Checker" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a protected disclosure under UK whistleblowing law?",
        "acceptedAnswer": { "@type": "Answer", "text": "A protected disclosure is a report made by a worker (as defined by the Public Interest Disclosure Act 1998, which inserted sections 43A–43L into the Employment Rights Act 1996) in the reasonable belief that it is in the public interest, revealing one of six qualifying types of wrongdoing: a criminal offence, a breach of a legal obligation, a miscarriage of justice, a danger to health or safety, damage to the environment, or a deliberate cover-up of any of the above. The disclosure must be made to an appropriate recipient — typically your employer, a prescribed regulator, or in some cases the media." }
      },
      {
        "@type": "Question",
        "name": "Do I need to be an employee to be protected by whistleblowing law?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Whistleblowing protections under the Public Interest Disclosure Act 1998 (PIDA) apply to a broad category of 'workers', not just employees. This includes agency workers, NHS workers, contractors, and trainees. Self-employed contractors may also qualify in certain circumstances. The protections are wider than standard employment rights, which is one of the key advantages of a whistleblowing claim." }
      },
      {
        "@type": "Question",
        "name": "What counts as detriment after making a protected disclosure?",
        "acceptedAnswer": { "@type": "Answer", "text": "Detriment means any disadvantage imposed by your employer because of your whistleblowing. Examples include demotion, disciplinary action, being passed over for promotion, changes to your duties, exclusion from meetings, increased workload, being subjected to a hostile management style, or being dismissed. Dismissal connected to a protected disclosure is automatically unfair with no minimum service requirement, and compensation is uncapped." }
      },
      {
        "@type": "Question",
        "name": "Does my concern have to be true to qualify as a protected disclosure?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. You do not need to be correct that wrongdoing occurred. What matters is that you had a reasonable belief that the information tended to show one of the qualifying categories of wrongdoing, and that you reasonably believed the disclosure was in the public interest. If you acted honestly and reasonably, you are protected even if it later turns out you were wrong about the facts." }
      },
      {
        "@type": "Question",
        "name": "Can I be dismissed for whistleblowing?",
        "acceptedAnswer": { "@type": "Answer", "text": "Dismissal for making a protected disclosure is automatically unfair under UK employment law. Crucially, there is no minimum length of service required to bring this type of claim — unlike standard unfair dismissal which requires 2 years. Compensation is also uncapped, meaning tribunals can award very large sums in serious cases. If you were dismissed and believe it was connected to a protected disclosure, you should contact ACAS immediately to start the early conciliation process." }
      }
    ]
  }
];
---

<BaseLayout
  title={`Whistleblowing Rights Checker UK ${CURRENT_YEAR} — Am I Protected? | FairWorkCheck`}
  description={`Check whether your disclosure is legally protected under UK whistleblowing law. Find out if retaliation by your employer is actionable. Free tool, updated ${TAX_YEAR}.`}
  canonical="https://fairworkcheck.pakistanbill.online/tools/whistleblowing-rights-checker/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <!-- Ad Unit -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="tool-top">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center">
      <div class="text-xs text-gray-400 mb-1">Advertisement</div>
      <div class="h-14 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-xs max-w-3xl mx-auto"><!-- 728x90 --></div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-purple-50 text-purple-700 px-3 py-1.5 rounded-full text-xs font-semibold mb-5 border border-purple-100">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        9-question assessment · Takes 3 minutes
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
        Whistleblowing Rights Checker UK
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-6 max-w-2xl">
        Answer questions about what you reported, who you told, and what happened afterwards. Find out if your disclosure is legally protected and whether any retaliation is actionable under UK law.
      </p>
      <div class="flex flex-wrap gap-3">
        {['Free to Use', 'No Registration', 'Completely Private', `UK Law ${TAX_YEAR}`].map(badge => (
          <span class="inline-flex items-center gap-1.5 text-sm text-success bg-green-50 px-3 py-1 rounded-full border border-green-100 font-medium">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Main -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Checker Card -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-purple overflow-hidden">
            <div class="p-6 md:p-8">

              <!-- Progress -->
              <div class="mb-8" id="progress-section">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-text-primary">Question <span id="current-q">1</span> of 9</span>
                  <span class="text-sm text-text-secondary"><span id="progress-pct">0</span>% complete</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                  <div id="progress-bar" class="h-full rounded-full transition-all duration-500" style="width: 0%; background-color: #7c3aed;"></div>
                </div>
              </div>

              <!-- Questions -->
              <div id="questions-container">

                <!-- Q1 -->
                <div class="question-slide" id="q1" data-question="1">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 1 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">What type of wrongdoing did you report?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    UK whistleblowing law only protects disclosures about specific categories of wrongdoing. Personal grievances, complaints about your own treatment, or internal policy disagreements do not qualify on their own.
                  </p>
                  <div class="space-y-3" data-q="q1">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="criminal" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A criminal offence</span><span class="text-xs text-text-secondary">Fraud, theft, bribery, regulatory crime</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="legal_breach" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A breach of a legal obligation</span><span class="text-xs text-text-secondary">Breach of contract, regulatory non-compliance, tax evasion</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="health_safety" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A danger to health or safety</span><span class="text-xs text-text-secondary">Unsafe working conditions, unreported accidents, risk to the public</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="environment" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Environmental damage</span><span class="text-xs text-text-secondary">Illegal dumping, pollution, failure to comply with environmental law</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="miscarriage" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A miscarriage of justice</span><span class="text-xs text-text-secondary">Wrongful prosecution, concealment of evidence, judicial misconduct</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="cover_up" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A deliberate cover-up of any of the above</span><span class="text-xs text-text-secondary">Suppression of evidence, falsifying records</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q1" value="personal" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A personal grievance or workplace complaint</span><span class="text-xs text-text-secondary">My own treatment, management style, pay dispute</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q2 -->
                <div class="question-slide hidden" id="q2" data-question="2">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 2 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did you genuinely believe the wrongdoing was occurring or was likely to occur?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    You don't need to have proof. The law requires that you had a reasonable, honest belief — not certainty. However, making up or exaggerating concerns for personal advantage is not protected.
                  </p>
                  <div class="space-y-3" data-q="q2">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q2" value="yes_certain" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — I was certain the wrongdoing was happening</span><span class="text-xs text-text-secondary">I had direct knowledge or clear evidence</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q2" value="yes_reasonable" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — I had reasonable grounds to believe it</span><span class="text-xs text-text-secondary">I may not have had proof, but my concern was genuine and reasonable</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q2" value="unsure" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I suspected something was wrong but wasn't sure</span><span class="text-xs text-text-secondary">I reported it out of concern but wasn't certain</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q2" value="no" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">No — I reported it for other reasons</span><span class="text-xs text-text-secondary">I had a personal motive unrelated to the concern itself</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q3 -->
                <div class="question-slide hidden" id="q3" data-question="3">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 3 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did you believe your disclosure was in the public interest?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Since 2013, disclosures must be made in the public interest — not just for personal benefit. This doesn't mean you need to be altruistic; mixed motives are fine. But purely private disputes don't qualify.
                  </p>
                  <div class="space-y-3" data-q="q3">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q3" value="yes_clear" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — the wrongdoing affected the public, customers, or many workers</span><span class="text-xs text-text-secondary">Not just my own situation</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q3" value="yes_mixed" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Partly — it affected me personally but also others</span><span class="text-xs text-text-secondary">Mixed personal and public element</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q3" value="no" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">No — it mainly related to my own employment situation</span><span class="text-xs text-text-secondary">Pay, my own treatment, personal contractual dispute</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q4 -->
                <div class="question-slide hidden" id="q4" data-question="4">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 4 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Who did you make the disclosure to?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Who you report to matters. Reporting to your employer or an internal channel is always protected if the other criteria are met. Reporting to regulators or externally carries additional requirements.
                  </p>
                  <div class="space-y-3" data-q="q4">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q4" value="employer" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">My employer, manager, or internal whistleblowing channel</span><span class="text-xs text-text-secondary">Internal report — the most common route</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q4" value="regulator" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A prescribed regulator (FCA, CQC, HSE, HMRC etc.)</span><span class="text-xs text-text-secondary">Official regulatory body relevant to the sector</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q4" value="legal_adviser" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">A legal adviser (solicitor)</span><span class="text-xs text-text-secondary">For the purpose of getting legal advice</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q4" value="media" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">The press, media, or publicly</span><span class="text-xs text-text-secondary">This route carries stricter requirements</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q4" value="colleague" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Only a colleague or friend informally</span><span class="text-xs text-text-secondary">No formal report was made</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q5 -->
                <div class="question-slide hidden" id="q5" data-question="5">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 5 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">What is your working relationship with the organisation?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Whistleblowing protections cover a wider category of workers than standard employment rights. You don't need to be a traditional employee.
                  </p>
                  <div class="space-y-3" data-q="q5">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q5" value="employee" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I am a full employee (permanent or fixed-term)</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q5" value="worker" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I am a worker (zero hours, casual, agency)</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q5" value="contractor" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I am a contractor or freelancer working personally</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q5" value="trainee" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I am a trainee, intern, or student on placement</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q5" value="self_employed" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">I am fully self-employed with my own company</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q6 -->
                <div class="question-slide hidden" id="q6" data-question="6">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 6 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did your employer take any action against you after you made the disclosure?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Retaliation (called "detriment") is unlawful if it's connected to your protected disclosure. This is a separate claim from the disclosure itself being protected.
                  </p>
                  <div class="space-y-3" data-q="q6">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q6" value="dismissed" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — I was dismissed</span><span class="text-xs text-text-secondary">Dismissed after making the disclosure</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q6" value="detriment" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — I suffered detriment (but was not dismissed)</span><span class="text-xs text-text-secondary">Demotion, disciplinary, excluded, passed over for promotion, hostile treatment</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q6" value="constructive" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — the treatment forced me to resign</span><span class="text-xs text-text-secondary">Effectively constructive dismissal due to whistleblowing retaliation</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q6" value="none" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">No — I have not suffered any negative consequences yet</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q7 -->
                <div class="question-slide hidden" id="q7" data-question="7">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 7 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">How long after your disclosure did the negative treatment start?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Timing is important evidence. Detriment that follows soon after a disclosure is more easily linked to the whistleblowing. A long gap makes the causal connection harder to establish but doesn't make it impossible.
                  </p>
                  <div class="space-y-3" data-q="q7">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q7" value="immediate" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Within days or weeks of the disclosure</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q7" value="months" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">1 to 6 months after the disclosure</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q7" value="long" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">More than 6 months after the disclosure</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q7" value="na" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">No negative treatment has occurred</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q8 -->
                <div class="question-slide hidden" id="q8" data-question="8">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 8 of 9</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Does your employer know that you were the person who made the disclosure?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    For a detriment or dismissal claim to succeed, the employer's action must be because of your disclosure. If they didn't know it was you, the causal link is harder to establish — though circumstantial evidence can still support a claim.
                  </p>
                  <div class="space-y-3" data-q="q8">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q8" value="yes_certain" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">Yes — they know it was me</span><span class="text-xs text-text-secondary">I disclosed openly or they identified me</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q8" value="suspected" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">They probably suspect it was me</span><span class="text-xs text-text-secondary">Anonymous but I believe they can work out it was me</span></div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-400 hover:bg-purple-50/30 transition-all">
                      <input type="radio" name="q8" value="anonymous" class="mt-0.5 flex-shrink-0" style="accent-color:#7c3aed" />
                      <div><span class="font-semibold text-sm text-text-primary block">No — I reported anonymously and they don't know it was me</span></div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q9 -->
                <div class="question-slide hidden" id="q9" data-question="9">
                  <div class="mb-2"><span class="text-xs font-semibold uppercase tracking-wider" style="color:#7c3aed">Question 9 of 9</span></div>

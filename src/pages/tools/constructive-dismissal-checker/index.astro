---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Constructive Dismissal Checker' }
];

const relatedToolIds = ['tribunal-deadline', 'tupe-rights', 'settlement-tax'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Constructive Dismissal Checker UK",
    "url": "https://fairworkcheck.pakistanbill.online/tools/constructive-dismissal-checker/",
    "description": "Check whether your resignation could qualify as constructive dismissal under UK employment law with our free step-by-step assessment tool.",
    "applicationCategory": "LegalApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
    "provider": { "@type": "Organization", "name": "FairWorkCheck", "url": "https://fairworkcheck.co.uk" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fairworkcheck.pakistanbill.online/" },
      { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://fairworkcheck.pakistanbill.online/tools/" },
      { "@type": "ListItem", "position": 3, "name": "Constructive Dismissal Checker" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is constructive dismissal?",
        "acceptedAnswer": { "@type": "Answer", "text": "Constructive dismissal is when an employee resigns because their employer has seriously breached their employment contract, making it impossible for them to continue working there. You effectively treat yourself as dismissed because of your employer's conduct. To claim constructive dismissal at an employment tribunal, you must show there was a fundamental breach of contract, you resigned in response to that breach, and you did not delay too long after the breach before resigning." }
      },
      {
        "@type": "Question",
        "name": "Do I have to resign to claim constructive dismissal?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Constructive dismissal claims require you to actually resign your position. You cannot claim constructive dismissal while still employed. Once you resign, you must bring your claim to an employment tribunal within 3 months minus 1 day of your resignation date, after first contacting ACAS for Early Conciliation." }
      },
      {
        "@type": "Question",
        "name": "What counts as a fundamental breach of contract for constructive dismissal?",
        "acceptedAnswer": { "@type": "Answer", "text": "A fundamental breach is one that goes to the heart of your employment contract. Examples include: a significant reduction in pay without agreement, a demotion without consent, being subjected to harassment or bullying that the employer ignores, being required to work in a completely different role or location without agreement, the employer seriously undermining your authority, or a pattern of behaviour that cumulatively destroys trust and confidence." }
      },
      {
        "@type": "Question",
        "name": "Does it matter if I resigned immediately or waited?",
        "acceptedAnswer": { "@type": "Answer", "text": "Timing matters significantly in constructive dismissal claims. If you wait too long after the breach before resigning, a tribunal may conclude that you accepted (or 'affirmed') the breach of contract, which would defeat your claim. There is no fixed time limit, but generally speaking, waiting more than a few months after the triggering incident without resigning or raising a formal grievance can seriously weaken your case." }
      },
      {
        "@type": "Question",
        "name": "Should I raise a grievance before resigning for constructive dismissal?",
        "acceptedAnswer": { "@type": "Answer", "text": "It is strongly advisable to raise a formal grievance before resigning if circumstances allow. While it is not a legal requirement, failing to use your employer's grievance procedure can result in a reduction to your compensation of up to 25% under the ACAS Code of Practice. Raising a grievance also demonstrates that you tried to resolve the situation, which strengthens your credibility before a tribunal." }
      }
    ]
  }
];
---

<BaseLayout
  title={`Constructive Dismissal Checker UK ${CURRENT_YEAR} — Do I Have a Case? | FairWorkCheck`}
  description={`Find out if your resignation qualifies as constructive dismissal under UK law. Free step-by-step case strength checker. Updated for ${TAX_YEAR} employment law.`}
  canonical="https://fairworkcheck.pakistanbill.online/tools/constructive-dismissal-checker/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <!-- Ad Unit 1 -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="tool-top">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center">
      <div class="text-xs text-gray-400 mb-1">Advertisement</div>
      <div class="h-14 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-xs max-w-3xl mx-auto">
        <!-- 728x90 Leaderboard / 320x50 Mobile -->
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-3 py-1.5 rounded-full text-xs font-semibold mb-5 border border-blue-100">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        8-question assessment · Takes 2 minutes
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
        Constructive Dismissal Checker UK
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-6 max-w-2xl">
        Answer 8 questions about your situation and find out how strong your constructive dismissal claim is under UK employment law {TAX_YEAR}. Free, instant, and completely private.
      </p>
      <div class="flex flex-wrap gap-3">
        {['Free to Use', 'No Registration', 'Instant Results', `UK Law ${TAX_YEAR}`].map(badge => (
          <span class="inline-flex items-center gap-1.5 text-sm text-success bg-green-50 px-3 py-1 rounded-full border border-green-100 font-medium">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Section -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Quiz Card -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-orange overflow-hidden">
            <div class="p-6 md:p-8">

              <!-- Progress Bar -->
              <div class="mb-8" id="progress-section">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-text-primary">Question <span id="current-q">1</span> of 8</span>
                  <span class="text-sm text-text-secondary"><span id="progress-pct">0</span>% complete</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                  <div id="progress-bar" class="h-full bg-orange rounded-full transition-all duration-500" style="width: 0%"></div>
                </div>
              </div>

              <!-- Questions Container -->
              <div id="questions-container">

                <!-- Q1 -->
                <div class="question-slide" id="q1" data-question="1">
                  <div class="mb-2">
                    <span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 1 of 8</span>
                  </div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">
                    Did your employer seriously breach your employment contract?
                  </h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    This could be a breach of a written contract term (e.g. cutting your pay, changing your hours) or a breach of the implied duty of mutual trust and confidence (e.g. bullying, humiliation, ignoring your complaints).
                  </p>
                  <div class="space-y-3" data-q="q1">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all group">
                      <input type="radio" name="q1" value="yes_clear" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — there was a clear, serious breach</span>
                        <span class="text-xs text-text-secondary">e.g. unauthorised pay cut, demotion, systematic bullying</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all group">
                      <input type="radio" name="q1" value="yes_arguable" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Possibly — the situation was serious but not clear-cut</span>
                        <span class="text-xs text-text-secondary">e.g. increased workload, changed responsibilities, difficult management</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all group">
                      <input type="radio" name="q1" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — there was no specific breach</span>
                        <span class="text-xs text-text-secondary">I just found the work environment unpleasant</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q2 -->
                <div class="question-slide hidden" id="q2" data-question="2">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 2 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did your employer breach your actual employment contract or destroy mutual trust?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Constructive dismissal requires a breach of the employment contract — either an express term (written) or the implied term of mutual trust and confidence. Personal grievances with colleagues, general unhappiness, or minor management issues typically do not meet this test.
                  </p>
                  <div class="space-y-3" data-q="q2">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q2" value="yes_contract" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — a written contract term was breached</span>
                        <span class="text-xs text-text-secondary">e.g. pay, hours, job title, location changed without consent</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q2" value="yes_trust" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — my employer's behaviour destroyed trust and confidence</span>
                        <span class="text-xs text-text-secondary">e.g. bullying, harassment, unfair accusations, being undermined</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q2" value="unsure" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Unsure — the situation was unpleasant but unclear</span>
                        <span class="text-xs text-text-secondary">I am not sure if it technically breached any contract term</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q2" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — it was a personal/colleague issue, not employer conduct</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q3 -->
                <div class="question-slide hidden" id="q3" data-question="3">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 3 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did you resign because of your employer's breach — not for another reason?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    This is a critical legal test. You must show that the employer's breach was the main reason you resigned. If you resigned primarily for personal reasons (new job, relocation, family reasons) while the breach existed, your claim will likely fail.
                  </p>
                  <div class="space-y-3" data-q="q3">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q3" value="yes_clear" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — I resigned solely because of my employer's conduct</span>
                        <span class="text-xs text-text-secondary">I would not have resigned otherwise</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q3" value="yes_mainly" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Mainly yes — it was the primary reason, though not the only one</span>
                        <span class="text-xs text-text-secondary">The breach was the main reason but I also had other considerations</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q3" value="partially" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Partially — there were mixed reasons for my resignation</span>
                        <span class="text-xs text-text-secondary">I was already considering leaving and the breach accelerated my decision</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q3" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — I had already decided to leave for other reasons</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q4 -->
                <div class="question-slide hidden" id="q4" data-question="4">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 4 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">How quickly did you resign after the breach occurred?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Delay is a major risk factor. If you continue working for a long time after the breach without resigning or raising a grievance, a tribunal may decide you "affirmed" the contract — meaning you accepted the situation, which defeats your claim.
                  </p>
                  <div class="space-y-3" data-q="q4">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q4" value="immediate" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Within a few days to 2 weeks</span>
                        <span class="text-xs text-text-secondary">I resigned very shortly after the breach</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q4" value="weeks" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Within 2 to 8 weeks</span>
                        <span class="text-xs text-text-secondary">I resigned within a couple of months</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q4" value="months" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">2 to 6 months after the breach</span>
                        <span class="text-xs text-text-secondary">I stayed on for some time before eventually resigning</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q4" value="long" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">More than 6 months after the breach</span>
                        <span class="text-xs text-text-secondary">I stayed working for a significant period before resigning</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q5 -->
                <div class="question-slide hidden" id="q5" data-question="5">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 5 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Did you raise a formal grievance before resigning?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    While not legally required, raising a formal grievance strengthens your case and demonstrates you tried to resolve the situation. Failing to follow the ACAS Code of Practice on grievances can reduce your compensation by up to 25%.
                  </p>
                  <div class="space-y-3" data-q="q5">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q5" value="yes_formal" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — I raised a formal written grievance</span>
                        <span class="text-xs text-text-secondary">I followed the company grievance procedure</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q5" value="yes_informal" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">I complained informally but not through a formal process</span>
                        <span class="text-xs text-text-secondary">I raised concerns verbally or by email but not formally</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q5" value="no_reason" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — it was not possible or safe to do so</span>
                        <span class="text-xs text-text-secondary">e.g. the breach involved the HR department, there was no safe route</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q5" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — I did not raise any grievance</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q6 -->
                <div class="question-slide hidden" id="q6" data-question="6">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 6 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">How long had you worked for this employer at the time of resigning?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    For most types of unfair/constructive dismissal claims, you need 2 years of continuous employment. However, some exceptions apply — discrimination-based constructive dismissal has no minimum service requirement.
                  </p>
                  <div class="space-y-3" data-q="q6">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q6" value="over2" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">2 years or more</span>
                        <span class="text-xs text-text-secondary">I have the qualifying period for unfair dismissal</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q6" value="under2_discrimination" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Under 2 years — but the breach involved discrimination</span>
                        <span class="text-xs text-text-secondary">e.g. the conduct related to race, sex, disability, age, religion or sexual orientation</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q6" value="under2_whistleblowing" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Under 2 years — but I was a whistleblower</span>
                        <span class="text-xs text-text-secondary">I made a protected disclosure and was then treated badly</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="q6" value="under2" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Under 2 years — no discrimination or whistleblowing involved</span>
                        <span class="text-xs text-text-secondary">Standard employment situation</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an answer to continue.</p>
                </div>

                <!-- Q7 -->
                <div class="question-slide hidden" id="q7" data-question="7">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Question 7 of 8</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Do you have evidence of the breach?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Evidence significantly strengthens your case before a tribunal. This could include emails, letters, text messages, witness statements, payslips showing pay cuts, or written records of incidents.
                  </p>
                  <div class="space-y-3" data-q="q7">

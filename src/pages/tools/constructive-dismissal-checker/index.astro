<script>
  document.addEventListener('DOMContentLoaded', () => {
  // State
  let currentQuestion = 1;
  const totalQuestions = 8;
  const answers: Record<string, string> = {};

  const questions = document.querySelectorAll('.question-slide');
  const progressBar = document.getElementById('progress-bar');
  const currentQEl = document.getElementById('current-q');
  const progressPctEl = document.getElementById('progress-pct');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');
  const submitBtn = document.getElementById('submit-btn');
  const resultsSection = document.getElementById('results-section');

  function updateProgress() {
    const pct = Math.round(((currentQuestion - 1) / totalQuestions) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    if (currentQEl) currentQEl.textContent = String(currentQuestion);
    if (progressPctEl) progressPctEl.textContent = String(pct);
  }

  function showQuestion(n: number) {
    questions.forEach((q, i) => {
      if (i + 1 === n) q.classList.remove('hidden');
      else q.classList.add('hidden');
    });
    if (prevBtn) {
      if (n > 1) prevBtn.classList.remove('hidden');
      else prevBtn.classList.add('hidden');
    }
    if (n === totalQuestions) {
      nextBtn?.classList.add('hidden');
      submitBtn?.classList.remove('hidden');
    } else {
      nextBtn?.classList.remove('hidden');
      submitBtn?.classList.add('hidden');
    }
    updateProgress();
  }

  function getAnswer(qNum: number): string | null {
    const selected = document.querySelector(`input[name="q${qNum}"]:checked`) as HTMLInputElement;
    return selected ? selected.value : null;
  }

  function clearError(qNum: number) {
    const slide = document.getElementById(`q${qNum}`);
    slide?.querySelector('.error-msg')?.classList.add('hidden');
  }

  nextBtn?.addEventListener('click', () => {
    const answer = getAnswer(currentQuestion);
    if (!answer) {
      const slide = document.getElementById(`q${currentQuestion}`);
      slide?.querySelector('.error-msg')?.classList.remove('hidden');
      return;
    }
    clearError(currentQuestion);
    answers[`q${currentQuestion}`] = answer;
    currentQuestion++;
    showQuestion(currentQuestion);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  prevBtn?.addEventListener('click', () => {
    if (currentQuestion > 1) {
      currentQuestion--;
      showQuestion(currentQuestion);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  submitBtn?.addEventListener('click', () => {
    const answer = getAnswer(currentQuestion);
    if (!answer) {
      const slide = document.getElementById(`q${currentQuestion}`);
      slide?.querySelector('.error-msg')?.classList.remove('hidden');
      return;
    }
    answers[`q${currentQuestion}`] = answer;
    calculateResults();
  });

  document.getElementById('restart-btn')?.addEventListener('click', () => {
    currentQuestion = 1;
    Object.keys(answers).forEach(k => delete answers[k]);
    document.querySelectorAll('input[type="radio"]').forEach(r => (r as HTMLInputElement).checked = false);
    resultsSection?.classList.add('hidden');
    document.getElementById('progress-section')?.classList.remove('hidden');
    document.getElementById('nav-buttons')?.classList.remove('hidden');
    showQuestion(1);
  });

  // Score each answer
  function scoreAnswer(q: string, val: string): { score: number; label: string; positive: boolean; note: string } {
    const map: Record<string, Record<string, { score: number; label: string; positive: boolean; note: string }>> = {
      q1: {
        yes_clear:    { score: 2, label: 'Clear serious breach', positive: true, note: 'A clear fundamental breach is the foundation of your claim.' },
        yes_arguable: { score: 1, label: 'Possible breach — arguable', positive: true, note: 'This is arguable but will need strong supporting evidence.' },
        no:           { score: 0, label: 'No specific breach', positive: false, note: 'Without a fundamental breach, a constructive dismissal claim will not succeed.' },
      },
      q2: {
        yes_contract: { score: 2, label: 'Written contract breach', positive: true, note: 'Breach of an express contract term is a strong legal foundation.' },
        yes_trust:    { score: 2, label: 'Trust & confidence destroyed', positive: true, note: 'Destruction of mutual trust and confidence is a well-recognised basis for constructive dismissal.' },
        unsure:       { score: 1, label: 'Breach unclear', positive: false, note: 'Uncertainty about the nature of the breach is a significant weakness.' },
        no:           { score: 0, label: 'No contract breach', positive: false, note: 'Without a contract breach, your claim has no legal basis.' },
      },
      q3: {
        yes_clear:   { score: 2, label: 'Resigned solely due to breach', positive: true, note: 'The clearest possible causal link between breach and resignation.' },
        yes_mainly:  { score: 1, label: 'Breach was primary reason', positive: true, note: 'Good but the employer may argue other reasons motivated your resignation.' },
        partially:   { score: 0, label: 'Mixed reasons for resignation', positive: false, note: 'Mixed reasons significantly weaken the causal link test.' },
        no:          { score: 0, label: 'Resigned for other reasons', positive: false, note: 'If you had already decided to leave, your claim is very unlikely to succeed.' },
      },
      q4: {
        immediate: { score: 2, label: 'Resigned very promptly', positive: true, note: 'Prompt resignation is strong evidence you did not affirm the breach.' },
        weeks:     { score: 1, label: 'Resigned within weeks', positive: true, note: 'Still acceptable but a tribunal will want to understand the timeline.' },
        months:    { score: 0, label: 'Waited 2–6 months', positive: false, note: 'This raises a significant risk that you affirmed the breach by continuing to work.' },
        long:      { score: 0, label: 'Waited over 6 months', positive: false, note: 'A tribunal is likely to find you affirmed the breach. This is a serious weakness.' },
      },
      q5: {
        yes_formal:   { score: 1, label: 'Formal grievance raised', positive: true, note: 'Raising a formal grievance demonstrates you attempted to resolve the situation.' },
        yes_informal: { score: 1, label: 'Informal complaint made', positive: true, note: 'Helpful but a formal grievance would have been stronger.' },
        no_reason:    { score: 1, label: 'Could not safely raise grievance', positive: true, note: 'Valid reason for not grieving. Explain this clearly to a tribunal.' },
        no:           { score: 0, label: 'No grievance raised', positive: false, note: 'Failing to use the grievance procedure can reduce your compensation by up to 25%.' },
      },
      q6: {
        over2:                  { score: 1, label: '2+ years service', positive: true, note: 'You have the qualifying period for unfair/constructive dismissal claims.' },
        under2_discrimination:  { score: 1, label: 'Under 2 years — discrimination claim', positive: true, note: 'Discrimination-based constructive dismissal has no minimum service requirement.' },
        under2_whistleblowing:  { score: 1, label: 'Under 2 years — whistleblower', positive: true, note: 'Whistleblowing constructive dismissal has no minimum service requirement.' },
        under2:                 { score: 0, label: 'Under 2 years service', positive: false, note: 'You do not have the qualifying period for standard constructive dismissal. You may have other claims depending on the nature of the breach.' },
      },
      q7: {
        strong:  { score: 2, label: 'Strong documentary evidence', positive: true, note: 'Strong evidence significantly increases your prospects before a tribunal.' },
        some:    { score: 1, label: 'Some written evidence', positive: true, note: 'Some evidence is better than none. Gather everything you can.' },
        witness: { score: 1, label: 'Witness evidence available', positive: true, note: 'Witness evidence is valuable but documentary evidence is generally stronger.' },
        none:    { score: 0, label: 'Little or no evidence', positive: false, note: 'Without evidence, it becomes your word against your employer\'s, which is a significant risk.' },
      },
      q8: {
        single_serious: { score: 1, label: 'Single serious incident', positive: true, note: 'A clear single incident is straightforward for a tribunal to assess.' },
        pattern:        { score: 1, label: 'Last straw — pattern of conduct', positive: true, note: '"Last straw" cases are well-recognised in constructive dismissal law.' },
        ongoing:        { score: 1, label: 'Ongoing conduct', positive: true, note: 'Tribunals recognise ongoing conduct but you will need to identify specific incidents.' },
        unclear:        { score: 0, label: 'Unclear pattern', positive: false, note: 'If you cannot articulate specific incidents, this may be harder to prove.' },
      },
    };
    return map[q]?.[val] || { score: 0, label: 'Not answered', positive: false, note: '' };
  }

  function calculateResults() {
    let totalScore = 0;
    const factors: Array<{ label: string; positive: boolean; note: string; q: string }> = [];
    const warnings: string[] = [];

    for (let i = 1; i <= 8; i++) {
      const qKey = `q${i}`;
      const val = answers[qKey] || '';
      const result = scoreAnswer(qKey, val);
      totalScore += result.score;
      factors.push({ ...result, q: qKey });
    }

    // Determine verdict
    let verdictTitle = '';
    let verdictSubtitle = '';
    let badgeClass = '';

    if (totalScore >= 12) {
      verdictTitle = 'Strong Case';
      verdictSubtitle = 'Your answers suggest you have a strong constructive dismissal claim. You should seek legal advice promptly to take this forward.';
      badgeClass = 'border-green-400 text-green-600 bg-green-50';
    } else if (totalScore >= 8) {
      verdictTitle = 'Possible Case';
      verdictSubtitle = 'You may have a constructive dismissal claim but there are weaknesses. Legal advice is strongly recommended before taking any action.';
      badgeClass = 'border-amber-400 text-amber-600 bg-amber-50';
    } else if (totalScore >= 4) {
      verdictTitle = 'Weak Case';
      verdictSubtitle = 'There are significant weaknesses in your case as you have described it. Speak to a solicitor before deciding whether to proceed.';
      badgeClass = 'border-orange-400 text-orange-600 bg-orange-50';
    } else {
      verdictTitle = 'Very Difficult Case';
      verdictSubtitle = 'Based on your answers, you are likely to face very significant legal challenges. Seek specialist advice before taking any steps.';
      badgeClass = 'border-red-400 text-red-600 bg-red-50';
    }

    // Specific warnings
    if (answers.q4 === 'months' || answers.q4 === 'long') warnings.push('⚠️ Your delay in resigning is a significant risk. A tribunal may find you affirmed the breach.');
    if (answers.q6 === 'under2') warnings.push('⚠️ You do not have 2 years service. Standard constructive dismissal claims may not be available to you.');
    if (answers.q3 === 'no' || answers.q3 === 'partially') warnings.push('⚠️ Mixed or alternative reasons for your resignation seriously weaken the causal link test.');
    if (answers.q7 === 'none') warnings.push('⚠️ Lack of evidence means this becomes your word against your employer\'s. Gather any evidence you can immediately.');
    // Last straw doctrine — long delay + pattern of behaviour
    if ((answers.q4 === 'months' || answers.q4 === 'long') && answers.q8 === 'pattern') {
      warnings.push('ℹ️ Note: While a long delay usually weakens a claim, UK law allows for a "last straw" incident to revive older breaches where there is a pattern of conduct. The Employment Appeal Tribunal has held that the last act in a series need not itself be a breach — it merely needs to be the final incident that causes the employee to resign. You should discuss this specific timeline with an employment solicitor.');
    }
    if (answers.q5 === 'no') warnings.push('💡 Not raising a grievance can reduce your compensation by up to 25% if you succeed.');

    // Render results
    const scoreBadge = document.getElementById('score-badge');
    const scoreNumber = document.getElementById('score-number');
    const verdictTitleEl = document.getElementById('verdict-title');
    const verdictSubtitleEl = document.getElementById('verdict-subtitle');
    const factorsList = document.getElementById('factors-list');
    const findingsContent = document.getElementById('findings-content');
    const nextStepsEl = document.getElementById('next-steps');

    if (scoreBadge) scoreBadge.className = `inline-flex flex-col items-center justify-center w-32 h-32 rounded-full border-4 mb-4 ${badgeClass}`;
    if (scoreNumber) scoreNumber.textContent = String(totalScore);
    if (verdictTitleEl) verdictTitleEl.textContent = verdictTitle;
    if (verdictSubtitleEl) verdictSubtitleEl.textContent = verdictSubtitle;

    if (factorsList) {
      factorsList.innerHTML = factors.map(f => `
        <div class="flex items-start gap-3">
          <span class="flex-shrink-0 mt-0.5">${f.positive ? '✅' : '❌'}</span>
          <div>
            <span class="text-sm font-semibold ${f.positive ? 'text-green-700' : 'text-red-600'}">${f.label}</span>
            <p class="text-xs text-text-secondary mt-0.5">${f.note}</p>
          </div>
        </div>
      `).join('');
    }

    if (findingsContent) {
      if (warnings.length === 0) {
        findingsContent.innerHTML = '<p class="text-sm text-green-700">No major warnings identified based on your answers.</p>';
      } else {
        findingsContent.innerHTML = warnings.map(w => `<p class="text-sm text-text-secondary py-1">${w}</p>`).join('');
      }
    }

    const steps = totalScore >= 8 ? [
      '📞 Contact ACAS immediately: 0300 123 1100 — start Early Conciliation',
      '⚖️ Consult an employment solicitor — many offer free initial advice',
      '📋 Gather all evidence: emails, letters, payslips, records of incidents',
      '⏱️ Check your tribunal deadline with our Deadline Calculator',
      '📄 Do not discuss your claim on social media or with colleagues',
    ] : [
      '⚖️ Speak to an employment solicitor before taking any action',
      '📞 Call Citizens Advice on 0800 144 8848 for free guidance',
      '📋 Gather any evidence that supports your account of events',
      '💡 Consider whether alternative actions (grievance, mediation) are more appropriate',
      '⏱️ If you have already resigned, check your tribunal deadline urgently',
    ];

    if (nextStepsEl) {
      nextStepsEl.innerHTML = steps.map((step, i) => `
        <li class="flex items-start gap-3 text-sm text-gray-200">
          <span class="w-5 h-5 bg-orange rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5">${i+1}</span>
          <span>${step}</span>
        </li>
      `).join('');
    }

    // Show results
    document.getElementById('progress-section')?.classList.add('hidden');
    document.getElementById('nav-buttons')?.classList.add('hidden');
    questions.forEach(q => q.classList.add('hidden'));
    resultsSection?.classList.remove('hidden');
    resultsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Init
  showQuestion(1);
  });
</script>

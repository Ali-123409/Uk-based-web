---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ToolCard from '../../components/ToolCard.astro';
import { ALL_TOOLS } from '../../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../../data/config';

const tools = ALL_TOOLS;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free UK Employment Rights Tools",
  "url": "https://fairworkcheck.pakistanbill.online/tools/",
  "description": "Free interactive employment rights tools for UK workers. Check tribunal deadlines, dismissal claims, sick pay, TUPE rights and more.",
  "provider": { "@type": "Organization", "name": "FairWorkCheck" }
};
---

<BaseLayout
  title={`A-Z Directory of UK Employment Law Tools ${TAX_YEAR} | FairWorkCheck`}
  description={`Browse all free UK employment rights tools. Calculate tribunal deadlines, check dismissal claims, TUPE rights, sick pay calculators and more. Updated ${TAX_YEAR}.`}
  canonical="https://fairworkcheck.pakistanbill.online/tools/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'All Tools' }]} />

  <section class="bg-navy py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Free UK Employment Rights Tools</h1>
      <p class="text-gray-300 text-lg max-w-2xl">All tools are free, instant, and built for UK employment law 2025/26. No registration required.</p>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-xl font-bold text-text-primary mb-6">All Free Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-14">
        {tools.map(tool => <ToolCard {...tool} />)}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>



<style>
  .results-animate { animation: fadeInUp 0.4s ease forwards; }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .accent-navy { accent-color: #1a3c5e; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
  const totalSteps = 5;
  let currentStep = 1;
  const answers: Record<string, string> = {};

  const steps = document.querySelectorAll('.step-slide');
  const progressBar = document.getElementById('step-progress');
  const currentStepEl = document.getElementById('current-step');
  const stepPctEl = document.getElementById('step-pct');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');
  const submitBtn = document.getElementById('submit-btn');
  const resultsSection = document.getElementById('results-section');

  function updateProgress() {
    const pct = Math.round(((currentStep - 1) / totalSteps) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    if (currentStepEl) currentStepEl.textContent = String(currentStep);
    if (stepPctEl) stepPctEl.textContent = String(pct);
  }

  function showStep(n: number) {
    steps.forEach((s, i) => {
      if (i + 1 === n) s.classList.remove('hidden');
      else s.classList.add('hidden');
    });
    if (prevBtn) {
      n > 1 ? prevBtn.classList.remove('hidden') : prevBtn.classList.add('hidden');
    }
    if (n === totalSteps) {
      nextBtn?.classList.add('hidden');
      submitBtn?.classList.remove('hidden');
    } else {
      nextBtn?.classList.remove('hidden');
      submitBtn?.classList.add('hidden');
    }
    updateProgress();
  }

  function getAnswer(stepNum: number): string | null {
    const sel = document.querySelector(`input[name="s${stepNum}"]:checked`) as HTMLInputElement;
    return sel ? sel.value : null;
  }

  nextBtn?.addEventListener('click', () => {
    const ans = getAnswer(currentStep);
    if (!ans) {
      document.getElementById(`step${currentStep}`)?.querySelector('.error-msg')?.classList.remove('hidden');
      return;
    }
    document.getElementById(`step${currentStep}`)?.querySelector('.error-msg')?.classList.add('hidden');
    answers[`s${currentStep}`] = ans;
    currentStep++;
    showStep(currentStep);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  prevBtn?.addEventListener('click', () => {
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  submitBtn?.addEventListener('click', () => {
    const ans = getAnswer(currentStep);
    if (!ans) {
      document.getElementById(`step${currentStep}`)?.querySelector('.error-msg')?.classList.remove('hidden');
      return;
    }
    answers[`s${currentStep}`] = ans;
    calculateResults();
  });

  document.getElementById('restart-btn')?.addEventListener('click', () => {
    currentStep = 1;
    Object.keys(answers).forEach(k => delete answers[k]);
    document.querySelectorAll('input[type="radio"]').forEach(r => (r as HTMLInputElement).checked = false);
    resultsSection?.classList.add('hidden');
    document.getElementById('step-indicator')?.classList.remove('hidden');
    document.getElementById('nav-btns')?.classList.remove('hidden');
    showStep(1);
  });

  function calculateResults() {
    const s1 = answers.s1;
    const s2 = answers.s2;
    const s3 = answers.s3;
    const s4 = answers.s4;
    const s5 = answers.s5;

    // Determine TUPE applicability
    let tupeVerdict: 'likely' | 'possible' | 'unlikely' | 'complex' = 'likely';
    const warnings: string[] = [];
    const nextStepsList: string[] = [];

    // Core logic
    if (s1 === 'insolvency') {
      tupeVerdict = 'complex';
      warnings.push('⚠️ Insolvency situations have special TUPE rules. Some protections still apply but others are modified. You must seek specialist legal advice immediately.');
    }

    if (s2 === 'no') {
      tupeVerdict = 'unlikely';
      warnings.push('❌ If the service or activity is ceasing entirely, TUPE is unlikely to apply. TUPE requires the activity to continue with the new employer.');
    }

    if (s3 === 'self_employed') {
      tupeVerdict = 'unlikely';
      warnings.push('❌ Self-employed contractors are not covered by TUPE. However, if you believe you should be classified as an employee, seek legal advice about your employment status.');
    }

    if (s3 === 'agency') {
      tupeVerdict = 'possible';
      warnings.push('⚠️ Agency workers are generally not covered by TUPE as your employer is the agency, not the business. However, in some circumstances TUPE may apply. Seek specialist advice.');
    }

    if (s3 === 'worker') {
      tupeVerdict = 'possible';
      warnings.push('⚠️ TUPE applies to employees. If you are a worker rather than an employee, your coverage depends on the exact nature of your contract. Seek legal advice on your employment status.');
    }

    if (s4 === 'split') {
      if (tupeVerdict === 'likely') tupeVerdict = 'possible';
      warnings.push('⚠️ If you split your time equally across multiple services, whether TUPE applies to you individually depends on how you are assigned. Your employer should confirm which employees are assigned to the transferring service.');
    }

    if (s2 === 'unclear') {
      if (tupeVerdict === 'likely') tupeVerdict = 'possible';
      warnings.push('💡 It is unclear whether the activity will continue. You should formally ask your employer to clarify whether TUPE applies and what happens to your employment.');
    }

    // Employer notification warnings
    if (s5 === 'no') {
      warnings.push('🚨 Your employer has not notified you about the transfer. This is a potential breach of their duty to inform and consult. Each affected employee can claim up to 13 weeks\' pay in compensation.');
    }
    if (s5 === 'yes_partial') {
      warnings.push('⚠️ You have only been partially informed. Your employer must provide full written details. Request formal written notification from your employer or HR.');
    }
    if (s5 === 'changes_proposed') {
      warnings.push('🚨 Your employer is proposing to change your terms after the transfer. Changes to your contract because of a TUPE transfer are generally legally void. Do not agree to any changes without first seeking legal advice.');
    }

    // Set verdict UI
    const verdictBanner = document.getElementById('verdict-banner');
    const verdictIcon = document.getElementById('verdict-icon');
    const verdictTitle = document.getElementById('verdict-title');
    const verdictDesc = document.getElementById('verdict-desc');
    const rightsSection = document.getElementById('rights-section');
    const obligationsSection = document.getElementById('obligations-section');

    if (tupeVerdict === 'likely') {
      if (verdictBanner) verdictBanner.className = 'rounded-2xl p-6 mb-6 text-center bg-green-50 border border-green-200';
      if (verdictIcon) verdictIcon.textContent = '✅';
      if (verdictTitle) { verdictTitle.textContent = 'TUPE Likely Applies'; verdictTitle.className = 'font-heading text-2xl font-bold mb-2 text-green-800'; }
      if (verdictDesc) { verdictDesc.textContent = 'Based on your answers, TUPE is likely to apply to your transfer. Your employment rights should be fully protected. See your rights below.'; verdictDesc.className = 'text-sm leading-relaxed max-w-lg mx-auto text-green-700'; }
      rightsSection?.classList.remove('hidden');
      obligationsSection?.classList.remove('hidden');
      nextStepsList.push('✅ Your terms and conditions should transfer unchanged — do not sign any new contract without legal advice');
      nextStepsList.push('📋 Request written confirmation from your employer that TUPE applies to your transfer');
      nextStepsList.push('📄 Keep copies of your current contract, payslips and any communications about the transfer');
      nextStepsList.push('⚖️ If your new employer tries to change your terms, contact ACAS on 0300 123 1100 immediately');
      nextStepsList.push('💡 If you are dismissed connected to the transfer, seek urgent legal advice about an unfair dismissal claim');
    } else if (tupeVerdict === 'possible') {
      if (verdictBanner) verdictBanner.className = 'rounded-2xl p-6 mb-6 text-center bg-amber-50 border border-amber-200';
      if (verdictIcon) verdictIcon.textContent = '⚠️';
      if (verdictTitle) { verdictTitle.textContent = 'TUPE May Apply — Seek Clarification'; verdictTitle.className = 'font-heading text-2xl font-bold mb-2 text-amber-800'; }
      if (verdictDesc) { verdictDesc.textContent = 'Your situation has elements that could bring it within TUPE but there are factors that create uncertainty. You should seek legal advice to clarify your position before the transfer takes place.'; verdictDesc.className = 'text-sm leading-relaxed max-w-lg mx-auto text-amber-700'; }
      nextStepsList.push('⚖️ Seek legal advice from an employment solicitor before the transfer date');
      nextStepsList.push('📋 Formally ask your employer in writing whether TUPE applies and request their reasoning');
      nextStepsList.push('📞 Contact ACAS on 0300 123 1100 for free guidance on your specific situation');
      nextStepsList.push('📄 Keep copies of your contract, payslips and all communications about the transfer');
      nextStepsList.push('⏱️ If you believe TUPE has been breached, check your tribunal deadline with our Deadline Calculator');
    } else if (tupeVerdict === 'unlikely') {
      if (verdictBanner) verdictBanner.className = 'rounded-2xl p-6 mb-6 text-center bg-red-50 border border-red-200';
      if (verdictIcon) verdictIcon.textContent = '❌';
      if (verdictTitle) { verdictTitle.textContent = 'TUPE Unlikely to Apply'; verdictTitle.className = 'font-heading text-2xl font-bold mb-2 text-red-800'; }
      if (verdictDesc) { verdictDesc.textContent = 'Based on your answers, TUPE is unlikely to apply to your situation. However, you may have other employment rights. See the specific issues identified below and consider seeking legal advice.'; verdictDesc.className = 'text-sm leading-relaxed max-w-lg mx-auto text-red-700'; }
      nextStepsList.push('⚖️ Seek legal advice — you may have other employment rights even if TUPE does not apply');
      nextStepsList.push('📞 Call Citizens Advice on 0800 144 8848 for a free assessment of your situation');
      nextStepsList.push('💡 If you are being dismissed, check your redundancy rights and notice pay entitlement');
      nextStepsList.push('🔍 Consider whether your employment status (employee vs worker vs self-employed) is correctly classified');
    } else {
      if (verdictBanner) verdictBanner.className = 'rounded-2xl p-6 mb-6 text-center bg-purple-50 border border-purple-200';
      if (verdictIcon) verdictIcon.textContent = '⚖️';
      if (verdictTitle) { verdictTitle.textContent = 'Complex Situation — Specialist Advice Required'; verdictTitle.className = 'font-heading text-2xl font-bold mb-2 text-purple-800'; }
      if (verdictDesc) { verdictDesc.textContent = 'Insolvency TUPE situations are legally complex and different rules apply depending on the type of insolvency. You must seek specialist advice urgently.'; verdictDesc.className = 'text-sm leading-relaxed max-w-lg mx-auto text-purple-700'; }
      nextStepsList.push('🚨 Contact an employment solicitor immediately — insolvency TUPE is highly complex');
      nextStepsList.push('📞 Call Citizens Advice on 0800 144 8848 for emergency free guidance');
      nextStepsList.push('💡 Some TUPE protections still apply in insolvency — do not assume you have no rights');
      nextStepsList.push('📋 Keep copies of all communications from administrators or receivers');
    }

    // Render warnings
    const warningsList = document.getElementById('warnings-list');
    const warningsSection = document.getElementById('warnings-section');
    if (warningsList) {
      if (warnings.length === 0) {
        warningsSection?.classList.add('hidden');
      } else {
        warningsList.innerHTML = warnings.map(w =>
          `<div class="bg-amber-50 border border-amber-100 rounded-lg px-4 py-3 text-sm text-amber-800">${w}</div>`
        ).join('');
      }
    }

    // Render next steps
    const nextStepsEl = document.getElementById('next-steps');
    if (nextStepsEl) {
      nextStepsEl.innerHTML = nextStepsList.map((step, i) =>
        `<li class="flex items-start gap-3 text-sm text-gray-200">
          <span class="w-5 h-5 bg-orange rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5">${i+1}</span>
          <span>${step}</span>
        </li>`
      ).join('');
    }

    // Show results
    document.getElementById('step-indicator')?.classList.add('hidden');
    document.getElementById('nav-btns')?.classList.add('hidden');
    steps.forEach(s => s.classList.add('hidden'));
    resultsSection?.classList.remove('hidden');
    resultsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Init
  showStep(1);
  });
</script>

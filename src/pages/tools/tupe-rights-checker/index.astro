---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'TUPE Rights Checker' }
];

const relatedToolIds = ['tribunal-deadline', 'constructive-dismissal', 'settlement-tax'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TUPE Rights Checker UK",
    "url": "https://fairworkcheck.pakistanbill.online/tools/tupe-rights-checker/",
    "description": "Check whether TUPE regulations apply to your situation and understand your protected employment rights during a business transfer or outsourcing in the UK.",
    "applicationCategory": "LegalApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
    "provider": { "@type": "Organization", "name": "FairWorkCheck", "url": "https://fairworkcheck.pakistanbill.online" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fairworkcheck.pakistanbill.online/" },
      { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://fairworkcheck.pakistanbill.online/tools/" },
      { "@type": "ListItem", "position": 3, "name": "TUPE Rights Checker" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does TUPE mean and when does it apply?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TUPE stands for Transfer of Undertakings (Protection of Employment) Regulations 2006. It applies when a business or part of a business is transferred from one employer to another, or when a service (such as cleaning, security, or IT support) changes hands between contractors. When TUPE applies, employees automatically transfer to the new employer on the same terms and conditions, with their continuous employment preserved."
        }
      },
      {
        "@type": "Question",
        "name": "Does TUPE protect my pay and contract terms?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. One of the strongest protections TUPE provides is that your existing terms and conditions of employment transfer with you. The new employer cannot simply impose new contracts with worse terms. Any attempt to change your terms because of the transfer is legally void. There are very limited exceptions where changes may be permitted for economic, technical or organisational reasons, but these are tightly controlled."
        }
      },
      {
        "@type": "Question",
        "name": "Can I be made redundant because of a TUPE transfer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dismissal connected to a TUPE transfer is automatically unfair unless the employer can show an economic, technical or organisational reason entailing changes in the workforce (known as an ETO reason). Even if an ETO reason exists, standard unfair dismissal rules then apply. If you are dismissed in connection with a TUPE transfer and believe it is unfair, you should seek legal advice and consider an employment tribunal claim."
        }
      },
      {
        "@type": "Question",
        "name": "What information must my employer give me about a TUPE transfer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both the outgoing employer (transferor) and incoming employer (transferee) have legal obligations to inform and consult employee representatives before a TUPE transfer. They must provide: the fact that a transfer is happening and when, the legal, economic and social implications for employees, any measures envisaged in connection with the transfer, and information about the new employer. Failure to inform and consult can result in compensation of up to 13 weeks' pay per employee."
        }
      },
      {
        "@type": "Question",
        "name": "What if I do not want to transfer to the new employer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You have the right to object to transferring to the new employer. If you object, your employment ends on the date of transfer and you are not treated as having been dismissed — meaning you generally have no claim for unfair dismissal or redundancy pay. However, if the transfer involves a substantial change to your working conditions to your material detriment, you may be able to treat yourself as constructively dismissed and bring a claim."
        }
      }
    ]
  }
];
---

<BaseLayout
  title={`TUPE Rights Checker UK ${CURRENT_YEAR} — Does TUPE Apply to Me? | FairWorkCheck`}
  description={`Check whether TUPE applies to your situation and understand your protected employment rights during a business transfer or outsourcing. Free UK tool, updated ${TAX_YEAR}.`}
  canonical="https://fairworkcheck.pakistanbill.online/tools/tupe-rights-checker/"
  schema={schema}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <!-- Ad Unit 1 -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="tool-top">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center">
      <div class="text-xs text-gray-400 mb-1">Advertisement</div>
      <div class="h-14 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-xs max-w-3xl mx-auto">
        <!-- 728x90 Leaderboard / 320x50 Mobile -->
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-purple-50 text-purple-700 px-3 py-1.5 rounded-full text-xs font-semibold mb-5 border border-purple-100">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8 7h12m0 0l-4-4m4 4l-4 4M4 17h12m0 0l-4-4m4 4l-4 4"/></svg>
        Business transfer · Outsourcing · Service change
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
        TUPE Rights Checker UK
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-6 max-w-2xl">
        Being transferred to a new employer? Check whether TUPE applies to your situation, what your protected rights are, and exactly what your employer must do. Free, instant, updated for UK law {TAX_YEAR}.
      </p>
      <div class="flex flex-wrap gap-3">
        {['Free to Use', 'No Registration', 'Instant Results', `UK Law ${TAX_YEAR}`].map(badge => (
          <span class="inline-flex items-center gap-1.5 text-sm text-success bg-green-50 px-3 py-1 rounded-full border border-green-100 font-medium">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Tool Section -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Tool Card -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-orange overflow-hidden">
            <div class="p-6 md:p-8">

              <!-- Step indicator -->
              <div id="step-indicator" class="mb-8">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-text-primary">Step <span id="current-step">1</span> of 5</span>
                  <span class="text-sm text-text-secondary"><span id="step-pct">0</span>% complete</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                  <div id="step-progress" class="h-full bg-orange rounded-full transition-all duration-500" style="width:0%"></div>
                </div>
              </div>

              <!-- Steps Container -->
              <div id="steps-container">

                <!-- STEP 1: What is happening -->
                <div class="step-slide" id="step1">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Step 1 of 5</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">What is happening at your workplace?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Select the option that best describes your current situation. TUPE covers two main scenarios: business transfers and service provision changes.
                  </p>
                  <div class="space-y-3" id="s1-options">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s1" value="business_sale" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">The business (or part of it) is being sold to another company</span>
                        <span class="text-xs text-text-secondary">A new owner is taking over — share sale, asset sale, merger</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s1" value="outsourcing" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">A service is being outsourced to a contractor for the first time</span>
                        <span class="text-xs text-text-secondary">e.g. cleaning, security, catering, IT support being handed to an external provider</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s1" value="retendering" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">A service contract is being awarded to a different contractor</span>
                        <span class="text-xs text-text-secondary">e.g. the cleaning or security contract my employer currently holds is moving to a new company</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s1" value="insourcing" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">A previously outsourced service is being brought back in-house</span>
                        <span class="text-xs text-text-secondary">The client is taking direct control of a service they previously contracted out</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s1" value="insolvency" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">My employer is insolvent / going into administration</span>
                        <span class="text-xs text-text-secondary">The company is bankrupt or in administration proceedings</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an option to continue.</p>
                </div>

                <!-- STEP 2: Activity continuing -->
                <div class="step-slide hidden" id="step2">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Step 2 of 5</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Will the same or similar work continue after the transfer?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    For TUPE to apply, the activity or service must continue after the transfer — it cannot simply cease to exist. The work itself must carry on, even if under different management.
                  </p>
                  <div class="space-y-3" id="s2-options">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s2" value="yes_same" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — the same work will continue, just under a different employer</span>
                        <span class="text-xs text-text-secondary">The activity, service or business continues unchanged</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s2" value="yes_similar" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — similar work continues but with some changes</span>
                        <span class="text-xs text-text-secondary">The core activity is the same but processes or scope may differ slightly</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s2" value="unclear" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Unclear — I am not sure what the new employer plans to do</span>
                        <span class="text-xs text-text-secondary">The new employer's intentions regarding the work are unknown</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s2" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — the service or activity will cease entirely</span>
                        <span class="text-xs text-text-secondary">The work I currently do will not continue with the new employer</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an option to continue.</p>
                </div>

                <!-- STEP 3: Currently employed -->
                <div class="step-slide hidden" id="step3">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Step 3 of 5</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Are you currently employed by the transferring organisation?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    TUPE protects employees who are employed by the transferring employer immediately before the transfer. Agency workers and self-employed contractors are generally not covered, though there are exceptions.
                  </p>
                  <div class="space-y-3" id="s3-options">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s3" value="employee" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — I am a direct employee with a contract of employment</span>
                        <span class="text-xs text-text-secondary">I am employed directly, not through an agency or as self-employed</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s3" value="agency" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">I work through an agency — the agency is my employer</span>
                        <span class="text-xs text-text-secondary">I have a contract with an employment agency, not the business directly</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s3" value="self_employed" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">I am self-employed / work through my own limited company</span>
                        <span class="text-xs text-text-secondary">I am an independent contractor, not an employee</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s3" value="worker" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">I am a worker — not quite an employee but not self-employed</span>
                        <span class="text-xs text-text-secondary">Zero hours, casual or irregular work arrangements</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an option to continue.</p>
                </div>

                <!-- STEP 4: Dedicated to service -->
                <div class="step-slide hidden" id="step4">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Step 4 of 5</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Are you mainly assigned to the work or service that is transferring?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    For service provision change TUPE, you must be assigned to an organised grouping of employees dedicated to the transferring service. If you split your time across many different clients or services, TUPE may not apply to you individually.
                  </p>
                  <div class="space-y-3" id="s4-options">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s4" value="dedicated" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — I work mainly or exclusively on this contract or service</span>
                        <span class="text-xs text-text-secondary">The majority of my time is spent on the transferring work</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s4" value="mostly" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Mostly — but I also do some work on other contracts or services</span>
                        <span class="text-xs text-text-secondary">Majority of my time is on this service but I occasionally work elsewhere</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s4" value="split" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Split — I work across multiple contracts or clients roughly equally</span>
                        <span class="text-xs text-text-secondary">My time is spread across different services or client sites</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s4" value="business_transfer" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">This is a whole business transfer — not a service contract</span>
                        <span class="text-xs text-text-secondary">The entire business or business unit is being transferred, not just one service</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an option to continue.</p>
                </div>

                <!-- STEP 5: Employer behaviour -->
                <div class="step-slide hidden" id="step5">
                  <div class="mb-2"><span class="text-xs font-semibold text-orange uppercase tracking-wider">Step 5 of 5</span></div>
                  <h2 class="font-heading text-xl font-bold text-text-primary mb-2 leading-snug">Has your employer informed you about the transfer?</h2>
                  <p class="text-sm text-text-secondary mb-6 leading-relaxed">
                    Employers have a legal duty to inform and consult employee representatives before a TUPE transfer. The law requires them to provide specific information. This helps us assess whether your employer is meeting their obligations.
                  </p>
                  <div class="space-y-3" id="s5-options">
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s5" value="yes_full" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — I have been formally notified with full details</span>
                        <span class="text-xs text-text-secondary">Told about the transfer, timing, implications and any proposed changes</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s5" value="yes_partial" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Partially — I know something is happening but not full details</span>
                        <span class="text-xs text-text-secondary">I have been told informally or heard rumours but no formal notification</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s5" value="no" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">No — I have not been told anything officially</span>
                        <span class="text-xs text-text-secondary">I only found out through other means, or the transfer has already happened</span>
                      </div>
                    </label>
                    <label class="answer-option flex items-start gap-3 p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-navy/40 hover:bg-navy/3 transition-all">
                      <input type="radio" name="s5" value="changes_proposed" class="mt-0.5 accent-navy flex-shrink-0" />
                      <div>
                        <span class="font-semibold text-sm text-text-primary block">Yes — and the new employer wants to change my terms and conditions</span>
                        <span class="text-xs text-text-secondary">I have been told my pay, hours or contract terms will change after the transfer</span>
                      </div>
                    </label>
                  </div>
                  <p class="error-msg text-red-500 text-xs mt-2 hidden">Please select an option to continue.</p>
                </div>

              </div><!-- /steps-container -->

              <!-- Navigation -->
              <div class="flex gap-3 mt-8" id="nav-btns">
                <button id="prev-btn" class="hidden px-5 py-3 border border-gray-200 text-text-secondary hover:border-gray-300 rounded-lg transition-all text-sm font-medium">
                  ← Back
                </button>
                <button id="next-btn" class="flex-1 bg-orange hover:bg-orange-dark text-white font-semibold py-3.5 px-6 rounded-lg transition-all duration-200 hover:shadow-lg text-sm flex items-center justify-center gap-2">
                  Next Step
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
                <button id="submit-btn" class="hidden flex-1 bg-navy hover:bg-navy-dark text-white font-semibold py-3.5 px-6 rounded-lg transition-all text-sm flex items-center justify-center gap-2">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                  Check My TUPE Rights
                </button>
              </div>

              <!-- Results -->
              <div id="results-section" class="hidden mt-8 results-animate">
                <div class="border-t border-gray-100 pt-8">

                  <!-- Verdict Banner -->
                  <div id="verdict-banner" class="rounded-2xl p-6 mb-6 text-center">
                    <div id="verdict-icon" class="text-5xl mb-3"></div>
                    <h3 id="verdict-title" class="font-heading text-2xl font-bold mb-2"></h3>
                    <p id="verdict-desc" class="text-sm leading-relaxed max-w-lg mx-auto"></p>
                  </div>

                  <!-- TUPE Applies: Rights list -->
                  <div id="rights-section" class="hidden mb-5">
                    <h4 class="font-heading font-bold text-text-primary mb-4 flex items-center gap-2">
                      <span class="text-green-600">✅</span> Your Protected Rights Under TUPE
                    </h4>
                    <div class="space-y-3">
                      {[
                        { right: 'Contract Terms Preserved', detail: 'Your pay, hours, holiday entitlement and all other contract terms transfer unchanged to the new employer. Any attempt to impose worse terms because of the transfer is void.' },
                        { right: 'Continuous Employment Protected', detail: 'Your length of service is preserved. Your start date does not reset — your employment is treated as continuous with the new employer.' },
                        { right: 'Dismissal Protection', detail: 'Being dismissed solely because of the TUPE transfer is automatically unfair. The new employer must have an economic, technical or organisational reason to make changes.' },
                        { right: 'Right to Be Informed', detail: 'Both employers must inform you (via representatives) about the transfer, its implications, timing and any proposed measures before the transfer takes place.' },
                        { right: 'Right to Object', detail: 'You can object to transferring to the new employer. If you do, your employment ends but this is not treated as a dismissal in most circumstances.' },
                        { right: 'Pension Rights', detail: 'The new employer must provide broadly comparable pension arrangements if you were a member of an occupational pension scheme.' },
                      ].map(r => (

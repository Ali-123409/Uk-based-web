---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { ALL_TOOLS } from '../../../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../../../data/config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Discrimination Compensation Estimator' }
];

const relatedToolIds = ['tribunal-deadline', 'constructive-dismissal', 'acas-conciliation'];
const relatedTools = ALL_TOOLS.filter(t => relatedToolIds.includes(t.id));
---

<BaseLayout
  title={`Discrimination Estimator UK ${CURRENT_YEAR} | FairWorkCheck`}
  description={`Estimate workplace discrimination compensation. Updated for ${TAX_YEAR} Vento bands.`}
>
  <Header slot="header" />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card border-l-4 border-l-red-600 p-8">
            <h1 class="text-2xl font-bold mb-6">Discrimination Compensation Estimator</h1>
            <div class="space-y-4">
                <label class="block font-bold">Severity</label>
                <select id="severity" class="w-full border p-3 rounded">
                    <option value="low">Lower Band (One-off acts)</option>
                    <option value="mid">Middle Band (Serious)</option>
                    <option value="high">Upper Band (Severe)</option>
                </select>
                <button id="calc-btn" class="w-full bg-red-600 text-white py-3 rounded font-bold">Estimate Range</button>
            </div>
            <div id="results" class="hidden mt-8 border-t pt-8">
                <div class="text-xl font-bold" id="range-text"></div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-1 space-y-5">
          <div class="bg-white border rounded-xl p-5">
            <h3 class="font-bold text-sm mb-3">Vento Bands {TAX_YEAR}</h3>
            <div class="space-y-3 text-xs">
              {[
                { band: 'Lower', range: '£1,200 – £11,700', color: '#fbbf24', desc: 'Minor or one-off acts' },
                { band: 'Middle', range: '£11,700 – £35,200', color: '#f97316', desc: 'Moderately serious cases' },
                { band: 'Upper', range: '£35,200 – £58,700', color: '#dc2626', desc: 'Serious sustained cases' },
                { band: 'Exceptional', range: '£58,700+', color: '#7c2d12', desc: 'Most severe cases' },
              ].map(b => (
                <div class="flex items-center gap-2">
                  <div class="w-2 h-8 rounded" style={`background-color:${b.color}`}></div>
                  <div>
                    <p class="font-bold">{b.band}: {b.range}</p>
                    <p>{b.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">How Compensation is Calculated</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        {[
          { num: '01', title: 'Injury to Feelings', desc: 'Awarded using Vento bands depending on severity.' },
          { num: '02', title: 'Financial Loss', desc: 'Quantifiable damage like lost earnings.' },
          { num: '03', title: 'Aggravated Damages', desc: 'Additional award for particularly bad behavior.' },
        ].map(step => (
          <div>
            <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center font-bold mx-auto mb-3">{step.num}</div>
            <h3 class="font-bold mb-1">{step.title}</h3>
            <p class="text-sm text-gray-500">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
    document.getElementById('calc-btn')?.addEventListener('click', () => {
        const sev = (document.getElementById('severity') as HTMLSelectElement).value;
        const text = document.getElementById('range-text');
        if(text) text.textContent = "Estimated based on " + sev + " severity.";
        document.getElementById('results')?.classList.remove('hidden');
    });
</script>

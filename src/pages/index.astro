---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import { ALL_TOOLS } from '../data/tools';
import { TAX_YEAR, CURRENT_YEAR } from '../data/config';

const tools = ALL_TOOLS;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "FairWorkCheck",
    "url": "https://fairworkcheck.co.uk",
    "description": "Free interactive tools for UK workers to check employment rights, calculate deadlines, and understand their legal position.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://fairworkcheck.co.uk/tools/",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "FairWorkCheck",
    "url": "https://fairworkcheck.co.uk",
    "logo": "https://fairworkcheck.co.uk/og-default.jpg"
  }
];
---

<BaseLayout
  title={`FairWorkCheck | Free Employment Law Calculators & Checkers UK ${CURRENT_YEAR}`}
  description="Free interactive tools for UK workers. Calculate tribunal deadlines, check dismissal claims, TUPE rights, sick pay and settlement agreements instantly."
  schema={schema}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 20% 50%, #e8622a 0%, transparent 50%), radial-gradient(circle at 80% 20%, #ffffff 0%, transparent 40%);"></div>
    <div class="max-w-6xl mx-auto px-4 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-orange/15 text-orange px-3 py-1.5 rounded-full text-sm font-medium mb-6 border border-orange/20">
          <span class="w-2 h-2 bg-orange rounded-full animate-pulse"></span>
          Free · No Registration · UK Law 2025/26
        </div>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white font-bold leading-tight mb-6">
          Know Your Rights.<br />
          <span class="text-orange">Check Your Claim.</span>
        </h1>
        <p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-8 max-w-2xl">
          Free, accurate employment rights tools built specifically for UK workers. Get instant answers about tribunal deadlines, sick pay, dismissal claims and more.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/tools/" class="bg-orange hover:bg-orange-dark text-white font-semibold px-6 py-3 rounded-lg transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 inline-flex items-center gap-2">
            See All Tools
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/tools/employment-tribunal-deadline-calculator/" class="bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-lg transition-all duration-200 border border-white/20">
            Check My Deadline
          </a>
        </div>

        <!-- Trust stats -->
        <div class="flex flex-wrap gap-6 mt-10 pt-8 border-t border-white/10">
          <div>
            <div class="font-heading text-2xl text-white font-bold">10</div>
            <div class="text-gray-400 text-sm">Free Tools</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-white font-bold">UK</div>
            <div class="text-gray-400 text-sm">Law Specific</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-white font-bold">2025/26</div>
            <div class="text-gray-400 text-sm">Updated Rates</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-white font-bold">0</div>
            <div class="text-gray-400 text-sm">Registration Required</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Disclaimer Banner -->
  <div class="bg-amber-50 border-y border-amber-200">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-start gap-3">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c97b2a" stroke-width="2" class="flex-shrink-0 mt-0.5">
        <path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-sm text-amber-800">
        <strong>General information only.</strong> These tools do not constitute legal advice. Always consult a qualified employment solicitor for advice specific to your situation.
        <a href="/disclaimer/" class="underline hover:text-amber-900 ml-1">Read full disclaimer →</a>
      </p>
    </div>
  </div>

  <!-- Ad Unit 1 -->
  <div class="ad-unit bg-gray-50 border-b border-gray-100" data-ad-position="homepage-top">
    <div class="max-w-6xl mx-auto px-4 py-4 text-center">
      <div class="inline-block text-xs text-gray-400 mb-2">Advertisement</div>
      <div class="h-16 bg-white border border-gray-200 rounded flex items-center justify-center text-gray-300 text-sm max-w-3xl mx-auto">
        <!-- 728x90 Ad Unit -->
      </div>
    </div>
  </div>

  <!-- Tools Section -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-4">
          Free Employment Rights Tools
        </h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          All tools are free, instant, and built for UK law. No signup, no fees, no catch.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {tools.map(tool => (
          <ToolCard {...tool} />
        ))}
        <!-- Coming Soon placeholders -->
        <div class="bg-white rounded-xl border border-dashed border-gray-200 p-6 flex items-center justify-center text-center opacity-60">
          <div>
            <span class="text-2xl mb-2 block">🔔</span>
            <p class="text-sm text-text-secondary font-medium">More tools coming soon</p>
            <p class="text-xs text-gray-400 mt-1">Whistleblowing · Discrimination · Holiday Pay</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Use FairWorkCheck -->
  <section class="bg-white py-16 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-center text-text-primary mb-12">Why Workers Trust FairWorkCheck</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon: '🎯', title: 'UK-Specific', desc: 'Every tool is built for UK employment law, updated to 2025/26 rates and regulations.' },
          { icon: '⚡', title: 'Instant Results', desc: 'Get your answer in seconds. No waiting, no forms, no registration required.' },
          { icon: '🔒', title: 'Completely Private', desc: 'We never store your data. All calculations happen in your browser.' },
        ].map(item => (
          <div class="text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="font-heading font-semibold text-text-primary text-lg mb-2">{item.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero-bg { background-color: #1a3c5e; }
  
  
  .bg-orange-dark { background-color: #c94f1a; }
  .bg-orange\/15 { background-color: rgba(232,98,42,0.15); }
  .border-orange\/20 { border-color: rgba(232,98,42,0.20); }
  
  
  .hover\:bg-orange-dark:hover { background-color: #c94f1a; }
</style>

---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tools/', label: 'All Tools' },
  { href: '/about/', label: 'About' },
  { href: '/disclaimer/', label: 'Disclaimer' },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-navy sticky top-0 z-50 shadow-lg">
  <div class="max-w-6xl mx-auto px-4 py-0">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-orange rounded flex items-center justify-center flex-shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
            <path d="M9 12l2 2 4-4"/>
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          </svg>
        </div>
        <span class="font-heading text-xl text-white font-semibold tracking-tight group-hover:text-orange transition-colors">
          FairWork<span class="text-orange group-hover:text-white transition-colors">Check</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded text-sm font-medium transition-all duration-200 ${
              currentPath === link.href
                ? 'bg-orange text-white'
                : 'text-gray-300 hover:text-white hover:bg-white/10'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="md:hidden text-white p-2 rounded hover:bg-white/10 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-white/10 mt-0 pt-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-4 py-2.5 rounded text-sm font-medium mb-1 transition-colors ${
            currentPath === link.href
              ? 'bg-orange text-white'
              : 'text-gray-300 hover:text-white hover:bg-white/10'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  function isMenuOpen(): boolean {
    return !menu?.classList.contains('hidden');
  }

  // Toggle on burger click
  toggle?.addEventListener('click', () => {
    const opening = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(opening));
  });

  // Close when a nav link inside the mobile menu is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close when user clicks anywhere inside <main>
  document.querySelector('main')?.addEventListener('click', closeMenu);

  // Close on Escape key (WCAG 2.1 success criterion 1.4.13 / 2.1.2)
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && isMenuOpen()) {
      closeMenu();
      toggle?.focus(); // return focus to the trigger button
    }
  });
</script>

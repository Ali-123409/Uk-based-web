---
import { ALL_TOOLS } from '../data/tools';
const currentYear = new Date().getFullYear();
const tools = ALL_TOOLS.slice(0, 5);
---

<!-- Ad Unit 4 -->
<div class="ad-unit bg-gray-100 border-t border-gray-200" data-ad-position="footer">
  <div class="max-w-6xl mx-auto px-4 py-3 text-center">
    <div class="inline-block bg-white border border-gray-200 rounded text-xs text-gray-400 px-2 py-1 mb-2">Advertisement</div>
    <div class="h-16 bg-gray-50 rounded flex items-center justify-center text-gray-300 text-sm max-w-2xl mx-auto">
      <!-- 728x90 Ad Unit Here -->
    </div>
  </div>
</div>

<footer class="bg-navy-dark text-gray-300">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 bg-orange rounded flex items-center justify-center">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
              <path d="M9 12l2 2 4-4"/>
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </div>
          <span class="font-heading text-lg text-white font-semibold">FairWorkCheck</span>
        </div>
        <p class="text-sm text-gray-300 leading-relaxed">
          Free interactive tools for UK workers. Know your rights. Check your claim. Get informed.
        </p>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="font-heading text-white font-semibold mb-4 text-sm uppercase tracking-wider">Our Tools</h3>
        <ul class="space-y-2">
          {tools.map(tool => (
            <li>
              <a href={tool.href} class="text-sm text-gray-300 hover:text-orange transition-colors">
                {tool.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-heading text-white font-semibold mb-4 text-sm uppercase tracking-wider">Information</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-gray-400 hover:text-orange transition-colors">Home</a></li>
          <li><a href="/tools/" class="text-sm text-gray-400 hover:text-orange transition-colors">All Tools</a></li>
          <li><a href="/about/" class="text-sm text-gray-400 hover:text-orange transition-colors">About</a></li>
          <li><a href="/privacy-policy/" class="text-sm text-gray-400 hover:text-orange transition-colors">Privacy Policy</a></li>
          <li><a href="/disclaimer/" class="text-sm text-gray-400 hover:text-orange transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="border-t border-white/10 pt-6">
      <p class="text-xs text-gray-400 text-center leading-relaxed max-w-3xl mx-auto mb-3">
        <strong class="text-gray-300">Important:</strong> This website provides general information only and does not constitute legal advice. Always consult a qualified employment solicitor for advice specific to your circumstances.
      </p>
      <p class="text-xs text-gray-400 text-center">
        &copy; {currentYear} FairWorkCheck. All rights reserved. | <a href="/privacy-policy/" class="hover:text-gray-300 transition-colors">Privacy Policy</a> | <a href="/disclaimer/" class="hover:text-gray-300 transition-colors">Disclaimer</a>
      </p>
    </div>
  </div>
</footer>



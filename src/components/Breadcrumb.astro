---
export interface Props {
  items: { label: string; href?: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bg-white border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 py-2.5">
    <ol class="flex items-center gap-1.5 text-sm flex-wrap">
      {items.map((item, index) => (
        <li class="flex items-center gap-1.5">
          {index > 0 && (
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          )}
          {item.href ? (
            <a href={item.href} class="text-navy hover:text-orange transition-colors font-medium">
              {item.label}
            </a>
          ) : (
            <span class="text-text-secondary" aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>



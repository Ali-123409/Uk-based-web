---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
}
const { title, description, href, icon, badge } = Astro.props;
---

<a href={href} class="tool-card group block bg-white rounded-xl border border-gray-100 p-6 shadow-card hover:shadow-card-hover hover:border-orange/30 transition-all duration-300 hover:-translate-y-0.5">
  <div class="flex items-start gap-4">
    <div class="w-11 h-11 bg-navy/8 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-orange/10 transition-colors">
      <span class="text-xl">{icon}</span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1.5">
        <h3 class="font-heading font-semibold text-text-primary group-hover:text-navy transition-colors text-base leading-tight">{title}</h3>
        {badge && <span class="text-xs bg-orange/10 text-orange px-2 py-0.5 rounded-full font-medium flex-shrink-0">{badge}</span>}
      </div>
      <p class="text-sm text-text-secondary leading-relaxed">{description}</p>
      <div class="mt-3 flex items-center gap-1 text-orange text-sm font-medium">
        <span>Use tool free</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>
    </div>
  </div>
</a>


